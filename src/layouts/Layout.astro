---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { type Lang, defaultLang } from '../i18n/translations';
import { siteConfig } from '../data/config';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  noindex?: boolean;
}

const { 
  title, 
  description, 
  lang = defaultLang, 
  image = '/logo.png',
  type = 'website',
  noindex = false 
} = Astro.props;

const currentPath = Astro.url.pathname;

// Construire les chemins alternatifs pour hreflang
const getAlternatePath = (targetLang: string) => {
  if (currentPath.startsWith('/en/') || currentPath.startsWith('/fr/')) {
    return currentPath.replace(/^\/[^/]+/, `/${targetLang}`);
  }
  if (currentPath === '/en' || currentPath === '/fr') {
    return `/${targetLang}`;
  }
  return `/${targetLang}${currentPath === '/' ? '' : currentPath}`;
};

const enPath = getAlternatePath('en');
const frPath = getAlternatePath('fr');

// SEO descriptions par langue
const defaultDescriptions = {
  en: 'Electrical Engineer specialized in Power Systems, Embedded Systems, IoT, and Engineering Software Development. M.Sc. candidate with expertise in renewable energy and smart grids.',
  fr: "Ingénieur Électricien spécialisé en électroénergétique, systèmes embarqués, IoT et développement de logiciels d'ingénierie. Candidat M.Sc. avec expertise en énergies renouvelables et réseaux intelligents."
};

const finalDescription = description || defaultDescriptions[lang];
const fullTitle = title.includes('Alain Paluku') ? title : `${title} | Alain Paluku`;
const canonicalUrl = `https://${siteConfig.domain}${currentPath}`;
const imageUrl = image.startsWith('http') ? image : `https://${siteConfig.domain}${image}`;

// Structured Data (JSON-LD)
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Alain Paluku",
  "jobTitle": lang === 'en' ? "Electrical Engineer & Software Developer" : "Ingénieur Électricien & Développeur Logiciel",
  "description": finalDescription,
  "url": `https://${siteConfig.domain}`,
  "image": imageUrl,
  "sameAs": [
    "https://github.com/alainpaluku",
    "https://linkedin.com/in/alainpaluku",
    "https://medium.com/@alainpaluku"
  ],
  "knowsAbout": [
    "Electrical Engineering",
    "Power Systems",
    "Embedded Systems",
    "IoT Development",
    "Software Engineering",
    "Renewable Energy",
    "Smart Grids"
  ],
  "alumniOf": {
    "@type": "EducationalOrganization",
    "name": "Université de Kinshasa"
  }
};
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={finalDescription} />
    <meta name="keywords" content={lang === 'en' 
      ? "electrical engineer, power systems, embedded systems, IoT, software development, renewable energy, smart grids, Alain Paluku" 
      : "ingénieur électricien, électroénergétique, systèmes embarqués, IoT, développement logiciel, énergies renouvelables, réseaux intelligents, Alain Paluku"} />
    <meta name="author" content="Alain Paluku" />
    
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    
    <!-- SEO: Canonical & Hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={`https://${siteConfig.domain}${enPath}`} />
    <link rel="alternate" hreflang="fr" href={`https://${siteConfig.domain}${frPath}`} />
    <link rel="alternate" hreflang="x-default" href={`https://${siteConfig.domain}${enPath}`} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'fr_FR'} />
    <meta property="og:locale:alternate" content={lang === 'en' ? 'fr_FR' : 'en_US'} />
    <meta property="og:site_name" content="Alain Paluku Portfolio" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:creator" content="@alainpaluku" />
    
    <!-- Favicon et icônes PWA -->
    <link rel="icon" type="image/png" sizes="32x32" href="/logo.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/logo.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/logo.png" />
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f1f1f" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Alain Paluku" />
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    
    <title>{fullTitle}</title>
    
    <!-- Preload Critical Resources - Optimisé mobile -->
    <link rel="preload" href="/fonts/inter.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="dns-prefetch" href="//images.unsplash.com" />
    <link rel="dns-prefetch" href="//api.github.com" />
    
    <!-- Optimisations mobiles critiques -->
    <meta name="format-detection" content="telephone=no" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    
    <!-- Resource Hints pour mobile -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Theme Detection - Évite le flash -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    
    <!-- Détection de langue optimisée pour mobile -->
    <script is:inline>
      (function() {
        const path = window.location.pathname;
        if (path === '/' || path === '/en/' || path === '/en' || path === '/fr/' || path === '/fr') {
          const hasVisited = sessionStorage.getItem('lang-detected');
          if (!hasVisited) {
            sessionStorage.setItem('lang-detected', 'true');
            const browserLang = navigator.language || navigator.userLanguage;
            const isFrench = browserLang.toLowerCase().startsWith('fr');
            const targetLang = isFrench ? 'fr' : 'en';
            const currentLang = path.includes('/fr') ? 'fr' : 'en';
            
            if (targetLang !== currentLang) {
              window.location.href = '/' + targetLang + '/';
            }
          }
        }
      })();
    </script>
    
    <!-- Performance monitoring pour mobile -->
    <script is:inline>
      // Optimisation: Désactiver les animations sur les appareils lents
      if (navigator.hardwareConcurrency && navigator.hardwareConcurrency <= 2) {
        document.documentElement.style.setProperty('--animation-duration', '0.1s');
      }
      
      // Optimisation: Réduire les effets sur les connexions lentes
      if (navigator.connection && navigator.connection.effectiveType === 'slow-2g') {
        document.documentElement.classList.add('reduce-motion');
      }
    </script>
  </head>
  <body class="antialiased overflow-x-hidden">
    <!-- Background Glow Effects -->
    <div class="fixed top-0 left-1/2 -translate-x-1/2 w-[300px] sm:w-[500px] lg:w-[800px] h-[300px] sm:h-[400px] lg:h-[600px] bg-[var(--color-glow-primary)] rounded-full blur-[80px] sm:blur-[100px] lg:blur-[120px] -z-10 pointer-events-none"></div>
    <div class="fixed bottom-0 right-0 w-[200px] sm:w-[400px] lg:w-[600px] h-[200px] sm:h-[400px] lg:h-[600px] bg-[var(--color-glow-secondary)] rounded-full blur-[60px] sm:blur-[80px] lg:blur-[100px] -z-10 pointer-events-none"></div>
    
    <Navigation lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Scroll to Top Button -->
    <button 
      id="scroll-to-top" 
      class="scroll-top-btn fixed bottom-6 left-6 z-50 w-12 h-12 rounded-full bg-[var(--color-text)] text-[var(--color-bg)] flex items-center justify-center shadow-lg opacity-0 invisible transition-all duration-300 hover:scale-110 hover:shadow-xl"
      aria-label="Scroll to top"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>

    <script>
      import { initPremiumEffects } from '../scripts/premiumEffects';
      initPremiumEffects();
    </script>

    <!-- Optimisations mobiles intégrées -->
    <script is:inline>
      // Optimisations mobiles critiques
      (function() {
        const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
        const isLowEndDevice = navigator.hardwareConcurrency && navigator.hardwareConcurrency <= 2;
        
        if (isMobile || isLowEndDevice) {
          // Réduire les animations sur mobile
          document.documentElement.style.setProperty('--animation-duration', '0.2s');
          
          // Ajouter une classe pour les optimisations CSS
          document.documentElement.classList.add('mobile-optimized');
          
          // Désactiver le parallax sur mobile
          const style = document.createElement('style');
          style.textContent = `
            @media (max-width: 768px) {
              .parallax { transform: none !important; }
              .hover-lift:hover { transform: none !important; }
              .card-3d:hover { transform: none !important; }
            }
          `;
          document.head.appendChild(style);
        }
        
        // Améliorer le feedback tactile
        if (isMobile) {
          document.addEventListener('touchstart', function() {}, { passive: true });
        }
      })();
    </script>

    <script is:inline>
      const scrollBtn = document.getElementById('scroll-to-top');
      
      function toggleScrollBtn() {
        if (window.scrollY > 300) {
          scrollBtn.classList.remove('opacity-0', 'invisible');
          scrollBtn.classList.add('opacity-100', 'visible');
        } else {
          scrollBtn.classList.add('opacity-0', 'invisible');
          scrollBtn.classList.remove('opacity-100', 'visible');
        }
      }

      scrollBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      window.addEventListener('scroll', toggleScrollBtn);
      toggleScrollBtn();
    </script>
  </body>
</html>