---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { type Lang, defaultLang } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const { title, lang = defaultLang } = Astro.props;
const otherLang = lang === 'en' ? 'fr' : 'en';
const currentPath = Astro.url.pathname;

// SEO descriptions par langue
const descriptions = {
  en: 'M.Sc. Candidate in Power Systems | Embedded, IoT and CAD Software Developer. Specialized in Smart Grids, embedded systems, and energy data analysis.',
  fr: 'Candidat M.Sc. en Systèmes de Puissance | Développeur Embarqué, IoT et Logiciel CAO. Spécialisé dans les Smart Grids, systèmes embarqués et analyse énergétique.'
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={descriptions[lang]} />
    
    <!-- SEO: Canonical & Hreflang -->
    <link rel="canonical" href={currentPath} />
    <link rel="alternate" hreflang="en" href={currentPath.replace(`/${lang}`, '/en')} />
    <link rel="alternate" hreflang="fr" href={currentPath.replace(`/${lang}`, '/fr')} />
    <link rel="alternate" hreflang="x-default" href={currentPath.replace(`/${lang}`, '/en')} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={descriptions[lang]} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'fr_FR'} />
    <meta property="og:locale:alternate" content={lang === 'en' ? 'fr_FR' : 'en_US'} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={descriptions[lang]} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    
    <!-- Détection de langue du navigateur (seulement sur la page d'accueil) -->
    <script is:inline>
      (function() {
        // Ne rediriger que si on est sur la racine ou page d'accueil
        const path = window.location.pathname;
        if (path === '/' || path === '/en/' || path === '/en' || path === '/fr/' || path === '/fr') {
          const hasVisited = sessionStorage.getItem('lang-detected');
          if (!hasVisited) {
            sessionStorage.setItem('lang-detected', 'true');
            const browserLang = navigator.language || navigator.userLanguage;
            const isFrench = browserLang.toLowerCase().startsWith('fr');
            const targetLang = isFrench ? 'fr' : 'en';
            const currentLang = path.includes('/fr') ? 'fr' : 'en';
            
            if (targetLang !== currentLang) {
              window.location.href = '/' + targetLang + '/';
            }
          }
        }
      })();
    </script>
  </head>
  <body class="antialiased overflow-x-hidden">
    <!-- Background Glow Effects -->
    <div class="fixed top-0 left-1/2 -translate-x-1/2 w-[300px] sm:w-[500px] lg:w-[800px] h-[300px] sm:h-[400px] lg:h-[600px] bg-primary/20 rounded-full blur-[80px] sm:blur-[100px] lg:blur-[120px] -z-10 pointer-events-none"></div>
    <div class="fixed bottom-0 right-0 w-[200px] sm:w-[400px] lg:w-[600px] h-[200px] sm:h-[400px] lg:h-[600px] bg-secondary/10 rounded-full blur-[60px] sm:blur-[80px] lg:blur-[100px] -z-10 pointer-events-none"></div>
    
    <Navigation lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
