---
// Redirection intelligente vers la langue appropriée avec balises de vérification
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- Search Console Verification - Page racine -->
  <meta name="google-site-verification" content="ea2wJDtMa_WWDtXxaI335QuwvbzXXp4C0uA5tnek-JM" />
  <meta name="msvalidate.01" content="C000FA6C8E791F8E9673D588DA2AC5BC" />
  
  <title>Alain Paluku - Electrical Engineer | Embedded Systems | Software Developer</title>
  <meta name="description" content="Electrical Engineer specialized in Power Systems, Embedded Systems, and Software Development." />
  
  <!-- Redirection intelligente avec détection de langue -->
  <script>
    (function() {
      // Vérifier si l'utilisateur a déjà une préférence de langue
      const savedLang = localStorage.getItem('preferred-lang');
      
      if (savedLang && (savedLang === 'en' || savedLang === 'fr')) {
        window.location.href = '/' + savedLang + '/';
        return;
      }
      
      // Détecter la langue du navigateur
      const browserLang = navigator.language || (navigator as any).userLanguage;
      const isFrench = browserLang.toLowerCase().startsWith('fr');
      const targetLang = isFrench ? 'fr' : 'en';
      
      // Sauvegarder la préférence
      localStorage.setItem('preferred-lang', targetLang);
      
      // Rediriger
      window.location.href = '/' + targetLang + '/';
    })();
  </script>
  
  <!-- Fallback pour les navigateurs sans JavaScript -->
  <noscript>
    <meta http-equiv="refresh" content="0; url=/en/" />
  </noscript>
</head>
<body>
  <div style="text-align: center; padding: 50px; font-family: Arial, sans-serif;">
    <h1>Alain Paluku</h1>
    <p>Redirecting to your preferred language...</p>
    <p>
      <a href="/en/" style="margin: 0 10px;">English</a> | 
      <a href="/fr/" style="margin: 0 10px;">Français</a>
    </p>
  </div>
</body>
</html>