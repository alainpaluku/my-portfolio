---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Icon from '../../../components/Icon.astro';
import type { Lang } from '../../../i18n/translations';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  
  return projects.map((project) => ({
    params: { 
      lang: project.data.lang,
      slug: project.slug.split('/')[1]
    },
    props: { project },
  }));
}

const { project } = Astro.props;
const { lang } = Astro.params as { lang: Lang };
const { Content } = await project.render();

const labels = {
  en: {
    back: 'Back to Portfolio',
    viewDemo: 'View Live Demo',
    viewCode: 'View Source Code',
    featured: 'Featured Project',
  },
  fr: {
    back: 'Retour au Portfolio',
    viewDemo: 'Voir la Démo',
    viewCode: 'Voir le Code Source',
    featured: 'Projet Vedette',
  },
};

const t = labels[lang];
---

<Layout title={`${project.data.title} | ALAIN PALUKU`} lang={lang}>
  <article class="pt-20 sm:pt-24 pb-16 px-4 sm:px-6 max-w-5xl mx-auto">
    <!-- Back Link -->
    <a 
      href={`/${lang}/portfolio`}
      class="inline-flex items-center text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors mb-8 group"
    >
      <svg class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      {t.back}
    </a>

    <!-- Header -->
    <header class="mb-10">
      <!-- Category & Featured Badge -->
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="text-xs sm:text-sm text-accent uppercase tracking-wider font-mono bg-accent/10 px-3 py-1 rounded-full">
          {project.data.category}
        </span>
        {project.data.featured && (
          <span class="text-xs text-primary uppercase tracking-wider font-mono bg-primary/10 px-3 py-1 rounded-full flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            {t.featured}
          </span>
        )}
      </div>

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black mb-6 text-[var(--color-text)] tracking-tight">
        {project.data.title}
      </h1>

      <!-- Description -->
      <p class="text-lg sm:text-xl text-[var(--color-text-muted)] leading-relaxed max-w-3xl">
        {project.data.description}
      </p>
      
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mt-6">
        {project.data.tags.map((tag: string) => (
          <span class="px-3 py-1.5 text-sm bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-text)] font-medium">
            {tag}
          </span>
        ))}
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-wrap gap-4 mt-8">
        {project.data.demo && (
          <a 
            href={project.data.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary inline-flex items-center gap-2 text-base px-6 py-3"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            {t.viewDemo}
          </a>
        )}
        {project.data.github && (
          <a 
            href={project.data.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 border-2 border-[var(--color-border)] rounded-xl text-[var(--color-text)] hover:border-[var(--color-text)] hover:text-[var(--color-text)] transition-all font-medium"
          >
            <Icon name="github" size={20} />
            {t.viewCode}
          </a>
        )}
      </div>
    </header>

    <!-- Featured Image -->
    <div class="rounded-2xl lg:rounded-3xl overflow-hidden mb-12 border border-[var(--color-border)]">
      <img 
        src={project.data.image} 
        alt={project.data.title}
        width="1200"
        height="675"
        loading="eager"
        decoding="async"
        class="w-full h-auto object-cover"
      />
    </div>

    <!-- Content -->
    <div class="project-content article-content">
      <Content />
    </div>
  </article>
</Layout>

<style is:global>
  .project-content {
    color: var(--color-text-muted);
    line-height: 1.75;
  }
  
  .project-content h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  @media (min-width: 640px) {
    .project-content h2 {
      font-size: 1.875rem;
    }
  }
  
  .project-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  @media (min-width: 640px) {
    .project-content h3 {
      font-size: 1.5rem;
    }
  }
  
  .project-content h4 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .project-content p {
    margin-bottom: 1rem;
    font-size: 1rem;
  }
  
  @media (min-width: 640px) {
    .project-content p {
      font-size: 1.125rem;
    }
  }
  
  .project-content ul {
    margin-bottom: 1.5rem;
    padding-left: 0;
    list-style: none;
  }
  
  .project-content ul li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }
  
  @media (min-width: 640px) {
    .project-content ul li {
      font-size: 1.125rem;
    }
  }
  
  .project-content ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 0.5rem;
    height: 0.5rem;
    background-color: var(--color-accent);
    border-radius: 50%;
  }
  
  .project-content ol {
    margin-bottom: 1.5rem;
    padding-left: 0;
    list-style: none;
    counter-reset: item;
  }
  
  .project-content ol li {
    position: relative;
    padding-left: 2rem;
    margin-bottom: 0.5rem;
    font-size: 1rem;
    counter-increment: item;
  }
  
  @media (min-width: 640px) {
    .project-content ol li {
      font-size: 1.125rem;
    }
  }
  
  .project-content ol li::before {
    content: counter(item);
    position: absolute;
    left: 0;
    top: 0;
    width: 1.5rem;
    height: 1.5rem;
    background-color: var(--color-accent);
    color: var(--color-dark);
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .project-content strong {
    color: var(--color-text);
    font-weight: 600;
  }
  
  .project-content a {
    color: var(--color-accent);
  }
  
  .project-content a:hover {
    text-decoration: underline;
  }
  
  .project-content code {
    color: var(--color-accent);
    background-color: var(--color-card-bg);
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: monospace;
  }
  
  .project-content blockquote {
    border-left: 4px solid var(--color-accent);
    padding-left: 1.5rem;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    margin: 2rem 0;
    font-style: italic;
    font-size: 1.125rem;
    background-color: rgba(var(--color-accent-rgb), 0.05);
    border-radius: 0 0.5rem 0.5rem 0;
  }
  
  /* Les styles de tableaux sont maintenant gérés par article-content.css */
</style>

<script>
  import { initResponsiveTables } from '../../../scripts/tableResponsive';
  initResponsiveTables();
</script>
