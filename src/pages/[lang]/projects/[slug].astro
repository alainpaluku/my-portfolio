---
import Layout from '../../../layouts/Layout.astro';
import Icon from '../../../components/Icon.astro';
import { projects } from '../../../data/projects';
import type { Lang } from '../../../i18n/translations';

export async function getStaticPaths() {
  const paths = [];
  
  // Générer les chemins pour chaque projet dans chaque langue
  for (const project of projects) {
    paths.push({
      params: { 
        lang: 'en',
        slug: project.slug
      },
      props: { project, lang: 'en' },
    });
    paths.push({
      params: { 
        lang: 'fr',
        slug: project.slug
      },
      props: { project, lang: 'fr' },
    });
  }
  
  return paths;
}

const { project, lang } = Astro.props;

const labels = {
  en: {
    back: 'Back to Portfolio',
    viewDemo: 'View Live Demo',
    viewCode: 'View Source Code',
    featured: 'Featured Project',
    technologies: 'Technologies Used',
    overview: 'Project Overview',
    features: 'Key Features',
    implementation: 'Implementation Details',
  },
  fr: {
    back: 'Retour au Portfolio',
    viewDemo: 'Voir la Démo',
    viewCode: 'Voir le Code Source',
    featured: 'Projet Vedette',
    technologies: 'Technologies Utilisées',
    overview: 'Aperçu du Projet',
    features: 'Fonctionnalités Clés',
    implementation: 'Détails d\'Implémentation',
  },
};

const t = labels[lang];

// Contenu détaillé des projets
const projectDetails = {
  'ai-power-prediction': {
    en: {
      overview: 'An advanced machine learning system that predicts electrical power consumption patterns using historical data and weather information.',
      features: [
        'Real-time power consumption prediction',
        'Weather data integration',
        'Historical pattern analysis',
        'Grid optimization recommendations'
      ],
      implementation: 'Built using TensorFlow and Python, the system processes large datasets to identify consumption patterns and predict future demand with high accuracy.'
    },
    fr: {
      overview: 'Un système d\'apprentissage automatique avancé qui prédit les modèles de consommation électrique en utilisant des données historiques et météorologiques.',
      features: [
        'Prédiction en temps réel de la consommation',
        'Intégration des données météorologiques',
        'Analyse des modèles historiques',
        'Recommandations d\'optimisation du réseau'
      ],
      implementation: 'Construit avec TensorFlow et Python, le système traite de grandes bases de données pour identifier les modèles de consommation et prédire la demande future avec une grande précision.'
    }
  },
  'gohome': {
    en: {
      overview: 'A comprehensive IoT platform for home automation, enabling remote control and monitoring of various home devices.',
      features: [
        'Device management dashboard',
        'Real-time monitoring',
        'Automated scheduling',
        'Mobile app integration'
      ],
      implementation: 'Developed using Go for the backend with gRPC communication, React for the frontend, and Raspberry Pi for edge computing.'
    },
    fr: {
      overview: 'Une plateforme IoT complète pour la domotique, permettant le contrôle à distance et la surveillance de divers appareils domestiques.',
      features: [
        'Tableau de bord de gestion des appareils',
        'Surveillance en temps réel',
        'Planification automatisée',
        'Intégration d\'application mobile'
      ],
      implementation: 'Développé avec Go pour le backend avec communication gRPC, React pour le frontend, et Raspberry Pi pour l\'edge computing.'
    }
  }
  // Ajouter d'autres projets selon les besoins
};

const details = projectDetails[project.slug]?.[lang] || {
  overview: project.title[lang],
  features: [],
  implementation: ''
};
---

<Layout title={`${project.title[lang]} | ALAIN PALUKU`} lang={lang}>
  <article class="pt-20 sm:pt-24 pb-16 px-4 sm:px-6 max-w-5xl mx-auto">
    <!-- Back Link -->
    <a 
      href={`/${lang}/portfolio`}
      class="inline-flex items-center text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors mb-8 group"
    >
      <svg class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      {t.back}
    </a>

    <!-- Header -->
    <header class="mb-10">
      <!-- Category & Featured Badge -->
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="text-xs sm:text-sm text-[var(--color-accent)] uppercase tracking-wider font-mono bg-[var(--color-accent)]/10 px-3 py-1 rounded-full">
          {project.category[lang]}
        </span>
        {project.featured && (
          <span class="text-xs text-[var(--color-text)] uppercase tracking-wider font-mono bg-[var(--color-text)]/10 px-3 py-1 rounded-full flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            {t.featured}
          </span>
        )}
      </div>

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black mb-6 text-[var(--color-text)] tracking-tight">
        {project.title[lang]}
      </h1>

      <!-- Description -->
      <p class="text-lg sm:text-xl text-[var(--color-text-muted)] leading-relaxed max-w-3xl">
        {details.overview}
      </p>
      
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mt-6">
        {project.tags.map((tag: string) => (
          <span class="px-3 py-1.5 text-sm bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-text)] font-medium">
            {tag}
          </span>
        ))}
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-wrap gap-4 mt-8">
        {project.demo && (
          <a 
            href={project.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary inline-flex items-center gap-2 text-base px-6 py-3"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            {t.viewDemo}
          </a>
        )}
        {project.github && (
          <a 
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary inline-flex items-center gap-2 text-base px-6 py-3"
          >
            <Icon name="github" size={20} />
            {t.viewCode}
          </a>
        )}
      </div>
    </header>

    <!-- Featured Image -->
    <div class="rounded-2xl lg:rounded-3xl overflow-hidden mb-12 border border-[var(--color-border)]">
      <img 
        src={project.image} 
        alt={project.title[lang]}
        width="1200"
        height="675"
        loading="eager"
        decoding="async"
        class="w-full h-auto object-cover"
      />
    </div>

    <!-- Content -->
    <div class="project-content space-y-8">
      <!-- Overview -->
      <section>
        <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text)] mb-4 pb-2 border-b border-[var(--color-border)]">
          {t.overview}
        </h2>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
          {details.overview}
        </p>
      </section>

      <!-- Features -->
      {details.features.length > 0 && (
        <section>
          <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text)] mb-4 pb-2 border-b border-[var(--color-border)]">
            {t.features}
          </h2>
          <ul class="space-y-3">
            {details.features.map((feature: string) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[var(--color-accent)] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="text-[var(--color-text-muted)]">{feature}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Technologies -->
      <section>
        <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text)] mb-4 pb-2 border-b border-[var(--color-border)]">
          {t.technologies}
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          {project.tags.map((tag: string) => (
            <div class="bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-lg p-4 text-center">
              <span class="text-[var(--color-text)] font-medium">{tag}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Implementation -->
      {details.implementation && (
        <section>
          <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text)] mb-4 pb-2 border-b border-[var(--color-border)]">
            {t.implementation}
          </h2>
          <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
            {details.implementation}
          </p>
        </section>
      )}
    </div>
  </article>
</Layout>
