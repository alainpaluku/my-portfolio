---
import Layout from '../../layouts/Layout.astro';
import ServicesComponent from '../../components/Services.astro';
import { getStaticLangPaths } from '../../utils/lang';
import { getPageTitle } from '../../data/pageTitles';
import type { Lang } from '../../i18n/translations';

export function getStaticPaths() {
  return getStaticLangPaths();
}

const { lang } = Astro.params as { lang: Lang };
---

<Layout title={getPageTitle('services', lang)} lang={lang}>
  <div class="pt-16 sm:pt-20">
    <ServicesComponent lang={lang} />
  </div>
</Layout>
