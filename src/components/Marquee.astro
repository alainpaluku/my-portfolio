---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const items = t.marquee;
const colors = ['text-accent', 'text-secondary', 'text-primary'];
---

<div class="w-full overflow-hidden relative z-20 py-4 sm:py-6 lg:py-8">
  <div class="bg-[var(--color-bg-secondary)] border-y border-[var(--color-border)] py-2.5 sm:py-3 lg:py-4 -rotate-2 -mx-4 px-4">
    <div class="flex whitespace-nowrap animate-marquee">
      {[...items, ...items].map((item, i) => (
        <span class="text-xs sm:text-base lg:text-xl font-mono text-[var(--color-text-muted)] mx-3 sm:mx-6 lg:mx-8 flex items-center gap-1.5 sm:gap-2">
          <span class={colors[i % colors.length]}>+</span> {item}
        </span>
      ))}
    </div>
  </div>
</div>
