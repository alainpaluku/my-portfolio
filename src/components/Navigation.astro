---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import Icon from './Icon.astro';
import { siteConfig } from '../data/config';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === 'en' ? 'fr' : 'en';
const basePath = `/${lang}`;

// Récupérer le chemin actuel pour le switcher de langue
const currentPath = Astro.url.pathname;
// Remplacer /en/ ou /fr/ par l'autre langue
const otherLangPath = currentPath.replace(`/${lang}`, `/${otherLang}`);

// Liens vers les pages séparées
const navLinks = [
  { href: '/about', label: t.nav.about },
  { href: '/services', label: t.nav.services },
  { href: '/portfolio', label: t.nav.portfolio },
  { href: '/articles', label: t.nav.articles },
  { href: '/contact', label: t.nav.contact },
];

// Drapeaux SVG
const flags = {
  fr: `<rect fill="#ED2939" width="36" height="36"/><rect fill="#FFF" width="24" height="36"/><rect fill="#002395" width="12" height="36"/>`,
  en: `<rect fill="#00247D" width="36" height="36"/><path fill="#FFF" d="M0 0l36 27v-4L4 0H0zm36 0L0 27v-4L32 0h4z"/><path fill="#CF142B" d="M0 0l36 27v-2L2 0H0zm36 0L0 27v-2L34 0h2z"/><rect fill="#FFF" x="15" width="6" height="36"/><rect fill="#FFF" y="10.5" width="36" height="6"/><rect fill="#CF142B" x="16.5" width="3" height="36"/><rect fill="#CF142B" y="12" width="36" height="3"/>`,
};
---

<nav class="fixed w-full z-50 top-0 left-0 px-3 sm:px-6 py-2.5 sm:py-4 backdrop-blur-md bg-black/50 border-b border-white/5">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <a href={`${basePath}/`} class="text-base sm:text-xl md:text-2xl font-bold font-mono tracking-tighter">
      <span class="text-gradient">ALAIN</span> <span class="text-white">PALUKU</span>
    </a>
    
    <div class="hidden lg:flex space-x-6 xl:space-x-8">
      {navLinks.slice(0, 4).map(link => (
        <a href={`${basePath}${link.href}`} class="nav-link text-sm">{link.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-1.5 sm:gap-4">
      <!-- Language Switcher -->
      <a 
        href={otherLangPath} 
        class="flex items-center gap-1 sm:gap-2 text-[10px] sm:text-sm text-gray-400 hover:text-white transition-colors uppercase font-mono px-1.5 sm:px-3 py-1 rounded-full border border-white/10 hover:border-white/30"
        title={otherLang === 'fr' ? 'Version française' : 'English version'}
      >
        <span class="w-3.5 h-3.5 sm:w-4 sm:h-4 rounded-full overflow-hidden">
          <svg viewBox="0 0 36 36" class="w-full h-full" set:html={flags[otherLang]} />
        </span>
        <span class="hidden xs:inline sm:inline">{otherLang.toUpperCase()}</span>
      </a>
      
      <a href={`${basePath}/contact`} class="hidden md:flex group items-center gap-2 text-xs sm:text-sm font-bold uppercase tracking-wide hover:text-accent transition-colors">
        {t.nav.contact}
        <span class="group-hover:translate-x-1 transition-transform">↗</span>
      </a>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden text-white p-1" aria-label="Menu">
        <Icon name="menu" size={22} />
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden mt-4 pb-4 border-t border-white/10 pt-4">
    <div class="flex flex-col space-y-3">
      {navLinks.map(link => (
        <a href={`${basePath}${link.href}`} class="nav-link py-2">{link.label}</a>
      ))}
      <a href={otherLangPath} class="nav-link py-2 flex items-center gap-2">
        🌐 {otherLang === 'fr' ? 'Français' : 'English'}
      </a>
    </div>
  </div>
</nav>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
