---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import { getBasePath, switchLangInPath, isActivePath } from '../utils/routing';
import Icon from './Icon.astro';
import Button from './ui/Button.astro';
import ThemeSelector from './ui/ThemeSelector.astro';
import LanguageSelector from './ui/LanguageSelector.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === 'en' ? 'fr' : 'en';
const basePath = getBasePath(lang);

// Récupérer le chemin actuel pour le switcher de langue
const currentPath = Astro.url.pathname;
// Remplacer /en/ ou /fr/ par l'autre langue
const otherLangPath = switchLangInPath(currentPath, lang, otherLang);

// Liens vers les pages séparées
const navLinks = [
  { href: '', label: t.nav.home }, // Chemin vide pour la page d'accueil
  { href: '/about', label: t.nav.about },
  { href: '/portfolio', label: t.nav.portfolio },
  { href: '/articles', label: t.nav.articles },
  { href: '/contact', label: t.nav.contact },
];
---

<nav id="main-nav" class="fixed w-full z-[9999] top-0 left-0 px-3 sm:px-6 py-2.5 sm:py-4 backdrop-blur-md bg-[var(--color-bg)]/95 border-b border-transparent shadow-none transition-all duration-300">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <a href={`${basePath}/`} class="text-base sm:text-xl md:text-2xl font-bold font-mono tracking-tighter">
      <span class="text-gradient">ALAIN</span> <span class="text-[var(--color-text)]">PALUKU</span>
    </a>
    
    <div class="hidden lg:flex space-x-6 xl:space-x-8">
      {navLinks.slice(0, 4).map(link => {
        const isActive = isActivePath(currentPath, link.href, lang);
        return (
          <a 
            href={`${basePath}${link.href}`} 
            class={`nav-link text-sm ${isActive ? 'active' : ''}`}
          >
            {link.label}
          </a>
        );
      })}
    </div>

    <div class="flex items-center gap-1.5 sm:gap-3">
      <!-- Theme Selector -->
      <ThemeSelector lang={lang} />

      <!-- Language Selector -->
      <LanguageSelector lang={lang} currentPath={currentPath} />
      
      <a href={`${basePath}/contact`} class="hidden md:flex group items-center gap-2 text-xs sm:text-sm font-bold uppercase tracking-wide hover:text-[var(--color-text)] transition-colors">
        {t.nav.contact}
        <span>↗</span>
      </a>

      <!-- Mobile Menu Button - Cercle amélioré -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden w-10 h-10 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] hover:border-[var(--color-text-muted)] transition-all duration-200 flex items-center justify-center group"
        aria-label="Menu"
      >
        <span id="menu-icon-open" class="transition-all duration-200">
          <Icon name="menu" size={16} />
        </span>
        <span id="menu-icon-close" class="hidden transition-all duration-200">
          <Icon name="close" size={16} />
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden mt-4 pb-6 border-t border-[var(--color-border)] pt-6">
    <div class="flex flex-col items-center space-y-4">
      {navLinks.map(link => {
        const isActive = isActivePath(currentPath, link.href, lang);
        return (
          <a 
            href={`${basePath}${link.href}`} 
            class={`nav-link py-2 text-lg text-center w-full ${isActive ? 'active' : ''}`}
          >
            {link.label}
          </a>
        );
      })}
      <a href={otherLangPath} class="nav-link py-2 text-lg flex items-center justify-center gap-2 w-full">
        <Icon name="languages" size={20} />
        {otherLang === 'fr' ? 'Français' : 'English'}
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  menuBtn?.addEventListener('click', () => {
    const wasHidden = mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    menuBtn.setAttribute('aria-expanded', wasHidden ? 'true' : 'false');
  });

  // Nav border on scroll
  const nav = document.getElementById('main-nav');
  
  function updateNavBorder() {
    if (window.scrollY > 10) {
      nav?.classList.remove('border-transparent', 'shadow-none');
      nav?.classList.add('border-[var(--color-border)]', 'shadow-sm', 'dark:shadow-none');
    } else {
      nav?.classList.add('border-transparent', 'shadow-none');
      nav?.classList.remove('border-[var(--color-border)]', 'shadow-sm', 'dark:shadow-none');
    }
  }

  window.addEventListener('scroll', updateNavBorder);
  updateNavBorder();
</script>
