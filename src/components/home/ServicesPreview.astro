---
import { useTranslations, type Lang, defaultLang } from '../../i18n/translations';
import SectionHeader from '../SectionHeader.astro';
import Icon from '../Icon.astro';
import ServiceCard from '../cards/ServiceCard.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;

const services = [
  { icon: 'bolt' as const, title: t.services.power.title, items: t.services.power.items },
  { icon: 'chip' as const, title: t.services.embedded.title, items: t.services.embedded.items },
  { icon: 'document' as const, title: t.services.cad.title, items: t.services.cad.items },
];
---

<section class="py-12 sm:py-16 lg:py-24 px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
  <SectionHeader title={t.services.title} subtitle={t.services.subtitle} />

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 lg:gap-6 mb-8 sm:mb-10">
    {services.map((service) => (
      <ServiceCard 
        icon={service.icon}
        title={service.title}
        items={service.items}
      />
    ))}
  </div>

  <div class="text-center">
    <a href={`${basePath}/services`} class="btn-outline inline-flex items-center gap-2">
      {lang === 'fr' ? 'Voir tous les services' : 'View all services'}
      <Icon name="arrowRight" size={16} />
    </a>
  </div>
</section>
