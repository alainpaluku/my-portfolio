---
import { useTranslations, type Lang, defaultLang } from '../../i18n/translations';
import SectionHeader from '../SectionHeader.astro';
import Icon from '../Icon.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;

const services = [
  { icon: 'bolt' as const, title: t.services.power.title },
  { icon: 'chip' as const, title: t.services.embedded.title },
  { icon: 'document' as const, title: t.services.cad.title },
  { icon: 'automation' as const, title: t.services.automation.title },
];
---

<section class="py-8 sm:py-12 lg:py-16 xl:py-24 px-3 sm:px-4 md:px-6 lg:px-12 max-w-7xl mx-auto">
  <SectionHeader title={t.services.title} subtitle={t.services.subtitle} />

  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 sm:gap-6 mb-8 sm:mb-10">
    {services.map((service) => (
      <div class="glass-card p-4 sm:p-5 lg:p-6 rounded-xl group hover:shadow-xl transition-all duration-300">
        <div class="flex items-center gap-3 sm:gap-4">
          <div class="p-2.5 sm:p-3 bg-[var(--color-accent)] text-[var(--color-bg)] rounded-xl shadow-lg flex-shrink-0">
            <Icon name={service.icon} size={20} />
          </div>
          <h3 class="text-sm sm:text-base lg:text-lg font-bold text-[var(--color-text)]">{service.title}</h3>
        </div>
      </div>
    ))}
  </div>

  <div class="text-center">
    <a href={`${basePath}/services`} class="btn-outline inline-flex items-center gap-2">
      {lang === 'fr' ? 'Voir tous les services' : 'View all services'}
      <Icon name="arrowRight" size={16} />
    </a>
  </div>
</section>
