---
import { type Lang } from '../../i18n/translations';
import SectionHeader from '../SectionHeader.astro';

interface Props {
  title: string;
  subtitle: string;
  items: any[];
  cardComponent: any;
  viewAllLink: string;
  viewAllText: string;
  lang: Lang;
  maxItems?: number;
  gridCols?: string;
  sectionClass?: string;
}

const { 
  title, 
  subtitle, 
  items, 
  cardComponent: Card, 
  viewAllLink, 
  viewAllText,
  lang,
  maxItems = 3,
  gridCols = "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3",
  sectionClass = ""
} = Astro.props;

const previewItems = items.slice(0, maxItems);
---

<section class={`py-12 sm:py-16 lg:py-20 px-4 sm:px-6 md:px-12 max-w-7xl mx-auto ${sectionClass}`}>
  <SectionHeader title={title} subtitle={subtitle} />
  
  <!-- Grille des éléments -->
  <div class={`grid ${gridCols} gap-4 sm:gap-6 mb-8 sm:mb-12`}>
    {previewItems.map((item) => (
      <div class="stagger-item">
        <Card {...item} lang={lang} />
      </div>
    ))}
  </div>

  <!-- Bouton Voir Tout -->
  <div class="text-center">
    <a 
      href={viewAllLink}
      class="btn-primary btn-icon inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-primary)] text-[var(--color-bg)] font-semibold rounded-lg transition-all duration-300 hover:bg-[var(--color-secondary)] hover:shadow-lg hover:-translate-y-0.5 focus-ring"
    >
      <span>{viewAllText}</span>
      <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>

<style>
  .stagger-item {
    opacity: 0;
    animation: staggerIn 0.6s ease-out forwards;
  }

  .stagger-item:nth-child(1) { animation-delay: 0.1s; }
  .stagger-item:nth-child(2) { animation-delay: 0.2s; }
  .stagger-item:nth-child(3) { animation-delay: 0.3s; }
  .stagger-item:nth-child(4) { animation-delay: 0.4s; }
  .stagger-item:nth-child(5) { animation-delay: 0.5s; }
  .stagger-item:nth-child(6) { animation-delay: 0.6s; }

  @keyframes staggerIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>