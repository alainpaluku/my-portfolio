---
import { useTranslations, type Lang, defaultLang } from '../../i18n/translations';
import SectionHeader from '../SectionHeader.astro';
import Icon from '../Icon.astro';

interface Props {
  lang?: Lang;
  title: string;
  subtitle: string;
  ctaText: string;
  ctaLink: string;
  gridCols?: string;
  padding?: string;
  centered?: boolean;
  showBackground?: boolean;
}

const { 
  lang = defaultLang, 
  title, 
  subtitle, 
  ctaText, 
  ctaLink,
  gridCols = "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3",
  padding = "py-12 sm:py-16 lg:py-24 px-4 sm:px-6 md:px-12",
  centered = false,
  showBackground = false
} = Astro.props;

const basePath = `/${lang}`;
const fullCtaLink = ctaLink.startsWith('/') ? `${basePath}${ctaLink}` : ctaLink;
---

<section class={`${padding} max-w-7xl mx-auto ${showBackground ? 'relative overflow-hidden' : ''}`}>
  {showBackground && (
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[400px] sm:w-[600px] h-[300px] sm:h-[400px] bg-[var(--color-accent)]/20 rounded-full blur-[80px] sm:blur-[100px] -z-10"></div>
  )}
  
  <div class={centered ? "max-w-3xl mx-auto text-center relative z-10" : ""}>
    {centered ? (
      <div class="mb-8 sm:mb-10">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6 text-gradient uppercase tracking-wide">{title}</h2>
        <p class="text-[var(--color-text-muted)] text-base sm:text-lg px-4">{subtitle}</p>
      </div>
    ) : (
      <SectionHeader title={title} subtitle={subtitle} />
    )}

    <slot name="content" />

    {Astro.slots.has('grid') && (
      <div class={`grid ${gridCols} gap-4 sm:gap-6 mb-8 sm:mb-10`}>
        <slot name="grid" />
      </div>
    )}

    <div class="text-center">
      <a href={fullCtaLink} class="btn-primary inline-flex items-center gap-2 sm:gap-3">
        {ctaText}
        <Icon name="arrowRight" size={16} />
      </a>
    </div>
  </div>
</section>