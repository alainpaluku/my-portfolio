---
import { useTranslations, type Lang, defaultLang } from '../../i18n/translations';
import SectionPreview from '../base/SectionPreview.astro';
import { projects } from '../../data/projects';
import { getLocalizedPath } from '../../utils/routing';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<SectionPreview
  lang={lang}
  title={t.portfolio.title}
  subtitle={t.portfolio.subtitle}
  items={projects}
  cardType="project"
  viewAllText={t.portfolio.viewAll}
  viewAllHref={getLocalizedPath('/portfolio', lang)}
  itemsToShow={3}
/>
