---
import { useTranslations, type Lang, defaultLang } from '../../i18n/translations';
import SectionPreview from '../base/SectionPreview.astro';
import { articles } from '../../data/articles';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;
---

<SectionPreview
  lang={lang}
  title={t.articles.title}
  subtitle={t.articles.subtitle}
  items={articles}
  cardType="article"
  viewAllText={t.articles.viewAll}
  viewAllHref={`${basePath}/articles`}
  itemsToShow={3}
/>
