---
import { useTranslations, type Lang, defaultLang } from '../../i18n/translations';
import SectionHeader from '../SectionHeader.astro';
import Icon from '../Icon.astro';
import Card from '../base/Card.astro';
import Button from '../ui/Button.astro';
import { articles } from '../../data/articles';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;
const latestArticles = articles.slice(0, 3);
---

<section class="py-12 sm:py-16 lg:py-24 px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
  <SectionHeader title={t.articles.title} subtitle={t.articles.subtitle} />

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mb-8 sm:mb-10">
    {latestArticles.map((article) => (
      <Card 
        type="article"
        data={article}
        lang={lang}
        showLink={true}
        linkText={t.articles.readMore}
      />
    ))}
  </div>

  <div class="text-center">
    <Button
      href={`${basePath}/articles`}
      variant="outline"
      className="inline-flex items-center gap-2"
    >
      {t.articles.viewAll}
      <Icon name="arrowRight" size={16} />
    </Button>
  </div>
</section>
