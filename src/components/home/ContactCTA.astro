---
import { useTranslations, type Lang, defaultLang } from '../../i18n/translations';
import Icon from '../Icon.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;
---

<section class="py-20 sm:py-32 px-4 sm:px-6 md:px-12 relative">
  <!-- Background subtil -->
  <div class="absolute bottom-0 right-0 w-[300px] h-[200px] bg-[var(--color-glow-secondary)] rounded-full blur-[100px] opacity-20 -z-10"></div>
  
  <div class="max-w-4xl mx-auto text-center relative z-10">
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-6 text-[var(--color-text)]">
      {t.contact.subtitle}
    </h2>
    <p class="text-[var(--color-text-muted)] text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
      {t.contact.description}
    </p>
    <a href={`${basePath}/contact`} class="btn-primary inline-flex items-center gap-3">
      {t.contact.cta}
      <Icon name="arrowRight" size={16} />
    </a>
  </div>
</section>
