---
import { useTranslations, type Lang, defaultLang } from '../../i18n/translations';
import Icon from '../Icon.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;
---

<section class="py-16 sm:py-24 px-4 sm:px-6 md:px-12 relative overflow-hidden">
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[400px] sm:w-[600px] h-[300px] sm:h-[400px] bg-[var(--color-glow-secondary)] rounded-full blur-[80px] sm:blur-[100px] -z-10"></div>
  
  <div class="max-w-3xl mx-auto text-center relative z-10">
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6 text-gradient uppercase tracking-wide">{t.contact.subtitle}</h2>
    <p class="text-[var(--color-text-muted)] text-base sm:text-lg mb-8 sm:mb-10 px-4">{t.contact.description}</p>
    <a href={`${basePath}/contact`} class="btn-primary inline-flex items-center gap-2 sm:gap-3">
      {t.contact.cta}
      <Icon name="arrowRight" size={16} />
    </a>
  </div>
</section>
