---
import { useTranslations, type Lang, defaultLang } from '../../i18n/translations';
import Icon from '../Icon.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;

const skills = lang === 'fr'
  ? ['Électroénergétique', 'Systèmes Embarqués', 'Développement Logiciel']
  : ['Power Engineering', 'Embedded Systems', 'Software Development'];
---

<section class="py-16 sm:py-24 px-4 sm:px-6 max-w-7xl mx-auto">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Header -->
    <div class="mb-12">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-4">
        {t.about.title}
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg max-w-2xl mx-auto leading-relaxed">
        {t.about.intro}
      </p>
    </div>
    
    <!-- Skills -->
    <div class="flex flex-wrap justify-center gap-3 mb-10">
      {skills.map(skill => (
        <span class="px-4 py-2 text-sm bg-[var(--color-card-bg)] rounded-full text-[var(--color-text-muted)] border border-[var(--color-border)] hover:border-[var(--color-text-muted)] transition-colors">
          {skill}
        </span>
      ))}
    </div>

    <!-- CTA avec texte dans le cercle -->
    <a 
      href={`${basePath}/about`} 
      class="inline-flex items-center justify-center px-6 py-3 rounded-full border-2 border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-text)] hover:text-[var(--color-text)] transition-all duration-300 group"
    >
      <span class="text-sm font-medium mr-2">
        {lang === 'fr' ? 'En savoir plus' : 'Learn more'}
      </span>
      <Icon name="arrowRight" size={16} class="group-hover:translate-x-0.5 transition-transform" />
    </a>
  </div>
</section>