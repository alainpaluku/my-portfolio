---
import { useTranslations, type Lang, defaultLang } from '../../i18n/translations';
import Icon from '../Icon.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;

const skills = lang === 'fr'
  ? ['Électroénergétique', 'Électronique', 'Embarqué', 'CAO', "Logiciel d'ingénierie"]
  : ['Power Engineering', 'Electronics', 'Embedded', 'CAD', 'Engineering Software'];
---

<section class="py-16 sm:py-24 px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="section-title mb-4 sm:mb-6">{t.about.title}</h2>
    <p class="text-[var(--color-text-muted)] text-base sm:text-lg leading-relaxed mb-6 sm:mb-8 px-2">{t.about.intro}</p>
    
    <div class="flex flex-wrap justify-center gap-1.5 sm:gap-2 mb-8 sm:mb-10">
      {skills.map(skill => (
        <span class="px-3 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm bg-[var(--color-card-bg)] rounded-full text-[var(--color-text-muted)] border border-[var(--color-border)]">{skill}</span>
      ))}
    </div>

    <a href={`${basePath}/about`} class="btn-outline inline-flex items-center gap-2">
      {lang === 'fr' ? 'En savoir plus' : 'Learn more'}
      <Icon name="arrowRight" size={16} />
    </a>
  </div>
</section>
