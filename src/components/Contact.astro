---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import SectionHeader from './SectionHeader.astro';
import SocialLinks from './SocialLinks.astro';
import FloatingWhatsApp from './FloatingWhatsApp.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-12 sm:py-16 lg:py-24 px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
  <SectionHeader title={t.contact.title} subtitle={t.contact.subtitle} />

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10">
    <!-- Contact Form -->
    <div class="glass-card p-4 sm:p-6 lg:p-8 rounded-xl lg:rounded-2xl">
      <form class="space-y-3 sm:space-y-4 lg:space-y-5">
        <div>
          <label for="name" class="block text-xs sm:text-sm font-medium text-[var(--color-text-muted)] mb-1.5 sm:mb-2">{t.contact.name}</label>
          <input 
            type="text" 
            id="name" 
            name="name"
            class="w-full px-3 sm:px-4 py-2.5 sm:py-3 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-lg sm:rounded-xl text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-text)] transition-colors text-sm"
            placeholder="John Doe"
          />
        </div>
        <div>
          <label for="email" class="block text-xs sm:text-sm font-medium text-[var(--color-text-muted)] mb-1.5 sm:mb-2">{t.contact.email}</label>
          <input 
            type="email" 
            id="email" 
            name="email"
            class="w-full px-3 sm:px-4 py-2.5 sm:py-3 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-lg sm:rounded-xl text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-text)] transition-colors text-sm"
            placeholder="john@example.com"
          />
        </div>
        <div>
          <label for="message" class="block text-xs sm:text-sm font-medium text-[var(--color-text-muted)] mb-1.5 sm:mb-2">{t.contact.message}</label>
          <textarea 
            id="message" 
            name="message"
            rows="3"
            class="w-full px-3 sm:px-4 py-2.5 sm:py-3 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-lg sm:rounded-xl text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-text)] transition-colors resize-none text-sm"
            placeholder={lang === 'fr' ? 'Votre message...' : 'Your message...'}
          ></textarea>
        </div>
        <button type="submit" class="btn-primary w-full">{t.contact.send}</button>
      </form>
    </div>

    <!-- Contact Info -->
    <div class="space-y-4 sm:space-y-6">
      <div>
        <h3 class="text-base sm:text-lg lg:text-xl font-bold text-[var(--color-text)] mb-3 sm:mb-4 lg:mb-5">{t.contact.info}</h3>
        <SocialLinks variant="contact" />
      </div>
    </div>
  </div>
</section>

<!-- Bouton WhatsApp flottant -->
<FloatingWhatsApp message={lang === 'fr' ? "Bonjour! Je souhaiterais discuter d'un projet." : "Hello! I would like to discuss a project."} />
