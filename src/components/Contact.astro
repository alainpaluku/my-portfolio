---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import SectionHeader from './SectionHeader.astro';
import SocialLinks from './SocialLinks.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const chartData = [40, 60, 30, 80, 55, 70];
---

<section class="py-12 sm:py-16 lg:py-24 px-4 sm:px-6 md:px-12 max-w-7xl mx-auto relative overflow-hidden">
  <div class="glow-blob bottom-0 right-0 translate-x-1/2 w-[200px] sm:w-[300px] lg:w-[400px] h-[200px] sm:h-[300px] lg:h-[400px] bg-accent/20"></div>

  <SectionHeader title={t.contact.title} subtitle={t.contact.subtitle} />

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10">
    <!-- Contact Form -->
    <div class="glass-card p-4 sm:p-6 lg:p-8 rounded-xl lg:rounded-2xl">
      <form class="space-y-3 sm:space-y-4 lg:space-y-5">
        <div>
          <label for="name" class="block text-xs sm:text-sm font-medium text-[var(--color-text-muted)] mb-1.5 sm:mb-2">{t.contact.name}</label>
          <input 
            type="text" 
            id="name" 
            name="name"
            class="w-full px-3 sm:px-4 py-2.5 sm:py-3 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-lg sm:rounded-xl text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none focus:border-accent transition-colors text-sm"
            placeholder="John Doe"
          />
        </div>
        <div>
          <label for="email" class="block text-xs sm:text-sm font-medium text-[var(--color-text-muted)] mb-1.5 sm:mb-2">{t.contact.email}</label>
          <input 
            type="email" 
            id="email" 
            name="email"
            class="w-full px-3 sm:px-4 py-2.5 sm:py-3 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-lg sm:rounded-xl text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none focus:border-accent transition-colors text-sm"
            placeholder="john@example.com"
          />
        </div>
        <div>
          <label for="message" class="block text-xs sm:text-sm font-medium text-[var(--color-text-muted)] mb-1.5 sm:mb-2">{t.contact.message}</label>
          <textarea 
            id="message" 
            name="message"
            rows="3"
            class="w-full px-3 sm:px-4 py-2.5 sm:py-3 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-lg sm:rounded-xl text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none focus:border-accent transition-colors resize-none text-sm"
            placeholder={lang === 'fr' ? 'Votre message...' : 'Your message...'}
          ></textarea>
        </div>
        <button type="submit" class="btn-primary w-full">{t.contact.send}</button>
      </form>
    </div>

    <!-- Contact Info -->
    <div class="space-y-4 sm:space-y-6">
      <div>
        <h3 class="text-base sm:text-lg lg:text-xl font-bold text-[var(--color-text)] mb-3 sm:mb-4 lg:mb-5">{t.contact.info}</h3>
        <SocialLinks variant="contact" />
      </div>

      <!-- Dashboard Preview -->
      <div class="glass-card rounded-xl lg:rounded-2xl overflow-hidden">
        <div class="bg-[var(--color-bg-secondary)] px-3 py-2 flex items-center gap-1.5 sm:gap-2 border-b border-[var(--color-border)]">
          <div class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-red-500"></div>
          <div class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-yellow-500"></div>
          <div class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-green-500"></div>
          <span class="ml-2 text-[9px] sm:text-[10px] text-[var(--color-text-muted)] font-mono truncate">energy_dashboard.exe</span>
        </div>
        <div class="p-3 sm:p-4 lg:p-5 bg-slate-900 dark:bg-[#0f0f0f]">
          <div class="flex justify-between items-end mb-3">
            <div>
              <h4 class="text-gray-400 text-[9px] sm:text-[10px] uppercase">
                {lang === 'fr' ? 'Consommation Réseau' : 'Network Consumption'}
              </h4>
              <div class="text-lg sm:text-xl lg:text-2xl font-bold text-white">450.2 <span class="text-[10px] sm:text-xs text-gray-500">kW</span></div>
            </div>
            <div class="text-green-400 text-[10px] sm:text-xs font-mono">▲ 2.4%</div>
          </div>
          <div class="flex items-end gap-1 sm:gap-1.5 h-12 sm:h-16 lg:h-20">
            {chartData.map((h) => (
              <div class="w-1/6 bg-gray-700 rounded-t hover:bg-primary transition-colors" style={`height: ${h}%`}></div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
