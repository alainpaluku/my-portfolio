---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import FilteredGrid from './ui/FilteredGrid.astro';
import Card from './base/Card.astro';
import { articles, articleCategories } from '../data/articles';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

// Enrichir les articles avec les props nécessaires pour Card
const enrichedArticles = articles.map(article => ({
  ...article,
  readMoreText: t.articles.readMore
}));
---

<FilteredGrid
  title={t.articles.title}
  subtitle={t.articles.subtitle}
  items={enrichedArticles}
  categories={articleCategories}
  cardComponent={Card}
  filterId="articles-filters"
  gridId="articles-grid"
  cardClass="article-card"
  categoryKey="categoryKey"
  gridCols="grid-cols-1 sm:grid-cols-2 xl:grid-cols-3"
  lang={lang}
  cardType="article"
/>