---
import Icon from './Icon.astro';
import { siteConfig } from '../data/config';

interface Props {
  message?: string;
}

const { message = "Bonjour! Je suis intéressé par vos services." } = Astro.props;

// Encoder le message pour l'URL WhatsApp
const encodedMessage = encodeURIComponent(message);
const whatsappUrl = `${siteConfig.social.whatsapp}?text=${encodedMessage}`;
---

<!-- Bouton WhatsApp flottant -->
<div class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-50 animate-bounce-subtle">
  <a 
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="whatsapp-float group flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 bg-[var(--color-accent)] hover:bg-[var(--color-text)] text-[var(--color-bg)] hover:text-[var(--color-bg)] rounded-full shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110 focus:outline-none focus:ring-4 focus:ring-[var(--color-accent)]/30"
    title="Contactez-moi sur WhatsApp"
    aria-label="Contactez-moi sur WhatsApp"
  >
    <Icon name="whatsapp" size={20} />
    
    <!-- Pulse animation -->
    <div class="absolute inset-0 rounded-full bg-[var(--color-accent)] animate-ping opacity-20"></div>
  </a>
  
  <!-- Tooltip -->
  <div class="absolute bottom-full right-0 mb-2 px-3 py-2 bg-[var(--color-text)] text-[var(--color-bg)] text-sm rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap pointer-events-none shadow-lg">
    WhatsApp
    <div class="absolute top-full right-4 w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-[var(--color-text)]"></div>
  </div>
</div>

<style>
  @keyframes bounce-subtle {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }
  
  .animate-bounce-subtle {
    animation: bounce-subtle 2s infinite;
  }
  
  .whatsapp-float {
    box-shadow: 0 4px 20px var(--color-glow-primary);
  }
  
  .whatsapp-float:hover {
    box-shadow: 0 8px 30px var(--color-glow-primary);
  }
</style>