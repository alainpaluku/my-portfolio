---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import Icon from './Icon.astro';
import { siteConfig } from '../data/config';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;

const content = {
  en: {
    tagline: 'Bridging electrical engineering with modern software technologies.',
    quickLinks: 'Quick Links',
    services: 'Services',
    contact: 'Contact',
    location: 'Goma, DR Congo',
    available: 'Available for projects',
  },
  fr: {
    tagline: "Faire le pont entre l'ingénierie électrique et les technologies logicielles modernes.",
    quickLinks: 'Liens Rapides',
    services: 'Services',
    contact: 'Contact',
    location: 'Goma, RD Congo',
    available: 'Disponible pour projets',
  },
};

const c = content[lang];

const quickLinks = [
  { href: '/about', label: t.nav.about },
  { href: '/portfolio', label: t.nav.portfolio },
  { href: '/articles', label: t.nav.articles },
  { href: '/contact', label: t.nav.contact },
];

const serviceLinks = [
  { label: lang === 'fr' ? 'Réseaux Électriques' : 'Power Networks' },
  { label: lang === 'fr' ? 'Systèmes Embarqués' : 'Embedded Systems' },
  { label: lang === 'fr' ? 'Solutions IoT' : 'IoT Solutions' },
  { label: lang === 'fr' ? 'Logiciels CAO' : 'CAD Software' },
];

const socialLinks = [
  { name: 'github' as const, url: siteConfig.social.github },
  { name: 'medium' as const, url: siteConfig.social.medium },
  { name: 'huggingface' as const, url: siteConfig.social.huggingface },
  { name: 'reddit' as const, url: siteConfig.social.reddit },
];
---

<footer class="relative overflow-hidden border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
  <!-- Background Glow -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[300px] sm:w-[500px] h-[200px] sm:h-[300px] bg-accent/10 rounded-full blur-[100px] -z-10"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 sm:py-14 lg:py-16">
    <!-- Main Footer Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10 mb-10 sm:mb-12">
      
      <!-- Brand Column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={`${basePath}/`} class="inline-block mb-4">
          <span class="text-xl sm:text-2xl font-bold font-mono tracking-tighter">
            <span class="text-gradient">ALAIN</span> <span class="text-[var(--color-text)]">PALUKU</span>
          </span>
        </a>
        <p class="text-[var(--color-text-muted)] text-xs sm:text-sm leading-relaxed mb-4">{c.tagline}</p>
        
        <!-- Status Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-500/10 border border-green-500/20">
          <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
          <span class="text-[10px] sm:text-xs text-green-600 dark:text-green-400 font-medium">{c.available}</span>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-xs sm:text-sm font-bold text-[var(--color-text)] uppercase tracking-wider mb-4">{c.quickLinks}</h4>
        <ul class="space-y-2">
          {quickLinks.map(link => (
            <li>
              <a href={`${basePath}${link.href}`} class="text-[var(--color-text-muted)] hover:text-accent transition-colors text-xs sm:text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-xs sm:text-sm font-bold text-[var(--color-text)] uppercase tracking-wider mb-4">{c.services}</h4>
        <ul class="space-y-2">
          {serviceLinks.map(link => (
            <li class="text-[var(--color-text-muted)] text-xs sm:text-sm">{link.label}</li>
          ))}
        </ul>
      </div>

      <!-- Contact & Social -->
      <div>
        <h4 class="text-xs sm:text-sm font-bold text-[var(--color-text)] uppercase tracking-wider mb-4">{c.contact}</h4>
        <div class="space-y-3">
          <a href={`mailto:${siteConfig.email}`} class="flex items-center gap-2 text-[var(--color-text-muted)] hover:text-accent transition-colors text-xs sm:text-sm">
            <Icon name="email" size={14} />
            {siteConfig.email}
          </a>
          <div class="flex items-center gap-2 text-[var(--color-text-muted)] text-xs sm:text-sm">
            <Icon name="location" size={14} />
            {c.location}
          </div>
          
          <!-- Social Links -->
          <div class="flex gap-3 pt-3">
            {socialLinks.map(link => (
              <a 
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-[var(--color-card-bg)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-muted)] hover:bg-accent hover:text-dark hover:border-accent transition-all"
                title={link.name}
              >
                <Icon name={link.name} size={18} />
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-6 sm:pt-8 border-t border-[var(--color-border)] flex justify-center items-center">
      <p class="text-[var(--color-text-muted)] text-[10px] sm:text-xs">
        © {new Date().getFullYear()} ALAIN PALUKU. {t.footer.rights}
      </p>
    </div>
  </div>
</footer>
