---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import GitHubStats from './GitHubStats.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const stats = [
  { value: '5+', label: t.stats.years },
  { value: '15+', label: t.stats.projects, id: 'github-repos' },
  { value: '5', label: t.stats.publications },
  { value: '100%', label: t.stats.passion },
];
---

<!-- Inclure les stats GitHub -->
<GitHubStats />

<section class="py-12 sm:py-20 border-y border-[var(--color-border)] bg-[var(--color-bg-secondary)] backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8 text-center">
    {stats.map((stat, index) => (
      <div class="stat-number reveal" style={`animation-delay: ${index * 0.1}s`}>
        <h3 
          class="text-3xl sm:text-4xl md:text-5xl font-bold text-[var(--color-text)] mb-1 sm:mb-2 text-shadow-premium"
          id={stat.id}
        >
          {stat.value}
        </h3>
        <p class="text-[var(--color-text-muted)] text-[10px] sm:text-sm uppercase tracking-widest">{stat.label}</p>
      </div>
    ))}
  </div>
</section>

<script>
  // Déclaration de type pour TypeScript
  declare global {
    interface Window {
      githubStats?: {
        repos: number;
        stars: number;
        followers: number;
      };
    }
  }

  // Mettre à jour les statistiques GitHub quand elles sont disponibles
  function updateGitHubStats() {
    if (typeof window !== 'undefined' && window.githubStats) {
      const reposElement = document.getElementById('github-repos');
      if (reposElement && window.githubStats.repos) {
        reposElement.textContent = `${window.githubStats.repos}+`;
      }
    }
  }

  // Essayer de mettre à jour immédiatement
  updateGitHubStats();
  
  // Réessayer après un délai au cas où les stats ne seraient pas encore chargées
  setTimeout(updateGitHubStats, 1000);
</script>

