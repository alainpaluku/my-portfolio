---
import Icon from './Icon.astro';
import { siteConfig } from '../data/config';

interface Props {
  variant?: 'footer' | 'contact';
}

const { variant = 'footer' } = Astro.props;

const links = [
  { name: 'github' as const, url: siteConfig.social.github, label: 'GitHub' },
  { name: 'medium' as const, url: siteConfig.social.medium, label: 'Medium' },
  { name: 'huggingface' as const, url: siteConfig.social.huggingface, label: 'Hugging Face' },
  { name: 'reddit' as const, url: siteConfig.social.reddit, label: 'Reddit' },
  { name: 'email' as const, url: `mailto:${siteConfig.social.email}`, label: siteConfig.social.email },
];

const isFooter = variant === 'footer';
---

{isFooter ? (
  <div class="flex flex-wrap justify-center gap-4">
    {links.map(link => (
      <a 
        href={link.url} 
        target={link.name !== 'email' ? '_blank' : undefined}
        rel={link.name !== 'email' ? 'noopener noreferrer' : undefined}
        class="w-10 h-10 sm:w-12 sm:h-12 rounded-full glass-card flex items-center justify-center hover:bg-white hover:text-black transition-all"
        aria-label={link.label}
        title={link.label}
      >
        <Icon name={link.name} size={18} />
      </a>
    ))}
  </div>
) : (
  <div class="space-y-3">
    {links.map(link => (
      <a 
        href={link.url}
        target={link.name !== 'email' ? '_blank' : undefined}
        rel={link.name !== 'email' ? 'noopener noreferrer' : undefined}
        class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors group"
      >
        <span class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl glass-card flex items-center justify-center group-hover:bg-accent group-hover:text-black transition-all flex-shrink-0">
          <Icon name={link.name} size={18} />
        </span>
        <span class="text-sm sm:text-base truncate">{link.label}</span>
      </a>
    ))}
  </div>
)}
