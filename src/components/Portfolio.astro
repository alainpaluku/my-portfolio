---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import FilteredGrid from './ui/FilteredGrid.astro';
import ProjectCard from './cards/ProjectCard.astro';
import { projects, projectCategories } from '../data/projects';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

// Enrichir les projets avec les props nécessaires pour ProjectCard
const enrichedProjects = projects.map(project => ({
  ...project,
  showLink: true,
  linkText: t.portfolio.viewProject
}));
---

<FilteredGrid
  title={t.portfolio.title}
  subtitle={t.portfolio.subtitle}
  items={enrichedProjects}
  categories={projectCategories}
  cardComponent={ProjectCard}
  filterId="portfolio-filters"
  gridId="portfolio-grid"
  cardClass="project-card"
  categoryKey="categoryKey"
  gridCols="grid-cols-1 md:grid-cols-2"
  lang={lang}
/>