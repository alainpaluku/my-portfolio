---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import SectionHeader from './SectionHeader.astro';
import ProjectCard from './cards/ProjectCard.astro';
import { projects, projectCategories, type ProjectCategory } from '../data/projects';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const categories = Object.entries(projectCategories) as [ProjectCategory, { en: string; fr: string }][];
---

<section class="py-12 sm:py-16 lg:py-24 px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
  <SectionHeader title={t.portfolio.title} subtitle={t.portfolio.subtitle} />

  <!-- Filtres -->
  <div class="flex flex-wrap justify-center gap-2 sm:gap-3 mb-8 sm:mb-12" id="portfolio-filters">
    {categories.map(([key, label]) => (
      <button 
        data-filter={key}
        class={`filter-btn px-3 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm rounded-full border transition-all ${key === 'all' ? 'bg-accent text-dark border-accent' : 'border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-accent hover:text-accent'}`}
      >
        {label[lang]}
      </button>
    ))}
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6" id="portfolio-grid">
    {projects.map((project) => (
      <div class="project-card" data-category={project.categoryKey}>
        <ProjectCard 
          title={project.title}
          category={project.category}
          image={project.image}
          tags={project.tags}
          lang={lang}
          showLink={true}
          linkText={t.portfolio.viewProject}
        />
      </div>
    ))}
  </div>
</section>

<script>
  const filterBtns = document.querySelectorAll('#portfolio-filters .filter-btn');
  const projectCards = document.querySelectorAll('.project-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      
      filterBtns.forEach(b => {
        b.classList.remove('bg-accent', 'text-dark', 'border-accent');
        b.classList.add('border-[var(--color-border)]', 'text-[var(--color-text-muted)]');
      });
      btn.classList.add('bg-accent', 'text-dark', 'border-accent');
      btn.classList.remove('border-[var(--color-border)]', 'text-[var(--color-text-muted)]');
      
      projectCards.forEach(card => {
        const category = card.getAttribute('data-category');
        (card as HTMLElement).style.display = (filter === 'all' || category === filter) ? 'block' : 'none';
      });
    });
  });
</script>
