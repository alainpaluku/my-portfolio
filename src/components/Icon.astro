---
import { icons, type IconName } from './icons';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

const { name, size = 20, class: className = '' } = Astro.props;

// Icônes qui utilisent fill au lieu de stroke
const fillIcons = ['medium', 'huggingface', 'reddit'];
const useFill = fillIcons.includes(name);
---

<svg 
  xmlns="http://www.w3.org/2000/svg" 
  width={size} 
  height={size} 
  viewBox="0 0 24 24" 
  fill={useFill ? 'currentColor' : 'none'}
  stroke={useFill ? 'none' : 'currentColor'}
  stroke-width="2" 
  stroke-linecap="round" 
  stroke-linejoin="round"
  class={className}
  set:html={icons[name]}
/>
