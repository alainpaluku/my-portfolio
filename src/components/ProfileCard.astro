---
import Icon from './Icon.astro';
import { siteConfig } from '../data/config';
import { type Lang, defaultLang } from '../i18n/translations';

interface Props {
  lang?: Lang;
  showSocials?: boolean;
}

const { lang = defaultLang, showSocials = true } = Astro.props;

const socialLinks = [
  { name: 'github' as const, url: siteConfig.social.github, label: 'GitHub' },
  { name: 'medium' as const, url: siteConfig.social.medium, label: 'Medium' },
  { name: 'huggingface' as const, url: siteConfig.social.huggingface, label: 'Hugging Face' },
  { name: 'reddit' as const, url: siteConfig.social.reddit, label: 'Reddit' },
];

const title = lang === 'fr' 
  ? 'Candidat M.Sc. en Systèmes de Puissance | Développeur Embarqué, IoT et Logiciel CAO'
  : 'M.Sc. Candidate in Power Systems | Embedded, IoT and CAD Software Developer';
---

<div class="relative w-full max-w-sm sm:max-w-md mx-auto lg:mx-0">
  <!-- Background Blob -->
  <div class="absolute top-10 right-10 w-48 sm:w-64 h-48 sm:h-64 bg-gradient-to-br from-primary via-secondary to-accent rounded-full blur-3xl opacity-40"></div>
  
  <!-- Rotating Badge -->
  <div class="absolute -top-4 -right-4 z-20 hidden sm:block">
    <svg class="w-16 h-16 sm:w-20 sm:h-20 lg:w-24 lg:h-24 text-white animate-spin-slow" viewBox="0 0 100 100">
      <path id="circlePath" d="M 50, 50 m -37, 0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" fill="transparent" />
      <text font-size="10" fill="white" letter-spacing="2">
        <textPath href="#circlePath">
          ALAIN PALUKU • DEVELOPER •
        </textPath>
      </text>
    </svg>
  </div>

  <!-- Main Image Container -->
  <div class="rounded-[1.5rem] sm:rounded-[2rem] lg:rounded-[3rem] overflow-hidden border border-white/10 relative z-10 h-[300px] sm:h-[380px] lg:h-[480px]">
    <img 
      src={siteConfig.profileImage} 
      alt={siteConfig.name}
      class="w-full h-full object-cover"
      loading="eager"
    />
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-dark via-transparent to-transparent"></div>
  </div>

  <!-- Floating Glass Card -->
  <div class="absolute -bottom-20 sm:-bottom-16 left-1/2 transform -translate-x-1/2 w-[92%] sm:w-[100%] lg:w-[105%] bg-white/5 backdrop-blur-xl border border-white/10 rounded-xl sm:rounded-2xl p-3 sm:p-4 lg:p-5 shadow-2xl z-30">
    <p class="text-[11px] sm:text-xs lg:text-sm text-gray-300 leading-relaxed mb-3 sm:mb-4 text-center">
      {title}
    </p>
    
    {showSocials && (
      <div class="flex justify-center gap-2 sm:gap-3">
        {socialLinks.map(link => (
          <a 
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-8 h-8 sm:w-9 sm:h-9 lg:w-10 lg:h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-accent hover:text-dark transition-all"
            title={link.label}
          >
            <Icon name={link.name} size={14} />
          </a>
        ))}
      </div>
    )}
  </div>
</div>
