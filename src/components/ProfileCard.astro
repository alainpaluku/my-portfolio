---
import Icon from './Icon.astro';
import { siteConfig } from '../data/config';
import { type Lang, defaultLang } from '../i18n/translations';

interface Props {
  lang?: Lang;
  showSocials?: boolean;
}

const { lang = defaultLang, showSocials = true } = Astro.props;

const socialLinks = [
  { name: 'github' as const, url: siteConfig.social.github, label: 'GitHub' },
  { name: 'medium' as const, url: siteConfig.social.medium, label: 'Medium' },
  { name: 'huggingface' as const, url: siteConfig.social.huggingface, label: 'Hugging Face' },
  { name: 'reddit' as const, url: siteConfig.social.reddit, label: 'Reddit' },
];

const title = lang === 'fr' 
  ? 'Candidat M.Sc. en Systèmes de Puissance | Développeur Embarqué, IoT et Logiciel CAO'
  : 'M.Sc. Candidate in Power Systems | Embedded, IoT and CAD Software Developer';
---

<div class="relative w-full max-w-[260px] sm:max-w-xs md:max-w-sm lg:max-w-md mx-auto lg:mx-0">
  <!-- Background Blob -->
  <div class="absolute top-5 right-5 sm:top-10 sm:right-10 w-32 sm:w-40 md:w-48 lg:w-64 h-32 sm:h-40 md:h-48 lg:h-64 bg-gradient-to-br from-primary via-secondary to-accent rounded-full blur-3xl opacity-40"></div>
  
  <!-- Rotating Badge -->
  <div class="absolute -top-2 -right-2 sm:-top-3 sm:-right-3 z-20 hidden sm:block">
    <svg class="w-12 h-12 sm:w-14 sm:h-14 md:w-18 md:h-18 lg:w-24 lg:h-24 text-white animate-spin-slow" viewBox="0 0 100 100">
      <path id="circlePath" d="M 50, 50 m -37, 0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" fill="transparent" />
      <text font-size="10" fill="white" letter-spacing="2">
        <textPath href="#circlePath">
          ALAIN PALUKU • DEVELOPER •
        </textPath>
      </text>
    </svg>
  </div>

  <!-- Main Image Container -->
  <div class="rounded-2xl sm:rounded-3xl lg:rounded-[3rem] overflow-hidden border border-white/10 relative z-10 h-[200px] sm:h-[260px] md:h-[320px] lg:h-[420px]">
    <img 
      src={siteConfig.profileImage} 
      alt={siteConfig.name}
      class="w-full h-full object-cover"
      loading="eager"
    />
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-dark via-transparent to-transparent"></div>
  </div>

  <!-- Floating Glass Card -->
  <div class="absolute -bottom-16 sm:-bottom-14 md:-bottom-12 left-1/2 transform -translate-x-1/2 w-[calc(100%-8px)] sm:w-[100%] lg:w-[105%] max-w-[calc(100vw-32px)] bg-white/5 backdrop-blur-xl border border-white/10 rounded-xl sm:rounded-2xl p-2.5 sm:p-3 md:p-4 shadow-2xl z-30">
    <p class="text-[9px] sm:text-[10px] md:text-xs lg:text-sm text-gray-300 leading-snug sm:leading-relaxed mb-2 sm:mb-3 text-center">
      {title}
    </p>
    
    {showSocials && (
      <div class="flex justify-center gap-1.5 sm:gap-2 md:gap-2.5">
        {socialLinks.map(link => (
          <a 
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 lg:w-9 lg:h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-accent hover:text-dark transition-all"
            title={link.label}
          >
            <Icon name={link.name} size={10} class="sm:w-3 sm:h-3 md:w-3.5 md:h-3.5" />
          </a>
        ))}
      </div>
    )}
  </div>
</div>
