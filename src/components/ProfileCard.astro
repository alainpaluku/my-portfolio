---
import Icon from './Icon.astro';
import { siteConfig } from '../data/config';
import { socialLinks } from '../data/socialLinks';
import { type Lang, defaultLang } from '../i18n/translations';

interface Props {
  lang?: Lang;
  showSocials?: boolean;
}

const { lang = defaultLang, showSocials = true } = Astro.props;

const title = lang === 'fr' 
  ? 'Candidat M.Sc. en Systèmes de Puissance | Développeur Embarqué, IoT et Logiciel CAO'
  : 'M.Sc. Candidate in Power Systems | Embedded, IoT and CAD Software Developer';

const badgeText = lang === 'fr' ? 'ALAIN PALUKU • INGÉNIEUR •' : 'ALAIN PALUKU • ENGINEER •';
---

<div class="relative w-full max-w-[260px] sm:max-w-xs md:max-w-sm lg:max-w-md mx-auto lg:mx-0">
  <!-- Background Blob -->
  <div class="absolute top-5 right-5 sm:top-10 sm:right-10 w-32 sm:w-40 md:w-48 lg:w-64 h-32 sm:h-40 md:h-48 lg:h-64 bg-gradient-to-br from-primary via-secondary to-accent rounded-full blur-3xl opacity-40"></div>
  
  <!-- Rotating Badge with Blue Verification in center -->
  <div class="absolute -top-2 -right-2 sm:-top-3 sm:-right-3 z-30 hidden sm:block">
    <div class="relative">
      <svg class="w-12 h-12 sm:w-14 sm:h-14 md:w-18 md:h-18 lg:w-24 lg:h-24 text-[var(--color-text)] animate-spin-slow" viewBox="0 0 100 100">
        <path id="circlePath" d="M 50, 50 m -30, 0 a 30,30 0 1,1 60,0 a 30,30 0 1,1 -60,0" fill="transparent" />
        <text font-size="9" fill="currentColor" letter-spacing="1.5">
          <textPath href="#circlePath">
            {badgeText}
          </textPath>
        </text>
      </svg>
      <!-- Blue Verification Badge - centered -->
      <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
        <div class="w-5 h-5 sm:w-6 sm:h-6 md:w-7 md:h-7 lg:w-10 lg:h-10 bg-blue-500 rounded-full flex items-center justify-center shadow-lg">
          <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5 md:w-4 md:h-4 lg:w-6 lg:h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Image Container - behind glass card -->
  <div class="relative z-10 h-[200px] sm:h-[260px] md:h-[320px] lg:h-[420px] mb-[-10px] sm:mb-[-15px] md:mb-[-20px]">
    <img 
      src={siteConfig.profileImage} 
      alt={siteConfig.name}
      class="w-full h-full object-contain drop-shadow-2xl"
      loading="eager"
    />
  </div>

  <!-- Floating Glass Card -->
  <div class="relative left-1/2 transform -translate-x-1/2 w-[calc(100%-8px)] sm:w-[100%] lg:w-[105%] max-w-[calc(100vw-32px)] bg-[var(--color-card-bg)] backdrop-blur-xl border border-[var(--color-border)] rounded-xl sm:rounded-2xl p-2.5 sm:p-3 md:p-4 shadow-xl z-20">
    <p class="text-[9px] sm:text-[10px] md:text-xs lg:text-sm text-[var(--color-text)] leading-snug sm:leading-relaxed mb-2 sm:mb-3 text-center font-medium">
      {title}
    </p>
    
    {showSocials && (
      <div class="flex justify-center gap-2 sm:gap-2.5">
        {socialLinks.map(link => (
          <a 
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-8 h-8 sm:w-9 sm:h-9 md:w-10 md:h-10 rounded-lg bg-[var(--color-bg-secondary)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-muted)] hover:bg-[var(--color-accent)] hover:text-[var(--color-bg)] hover:border-[var(--color-accent)] transition-all duration-300"
            title={link.label}
          >
            <Icon name={link.name} size={16} />
          </a>
        ))}
      </div>
    )}
  </div>
</div>
