---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import { getLocalizedPath } from '../utils/routing';
import ProfileCard from './ProfileCard.astro';
import Button from './ui/Button.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<header class="relative min-h-screen flex items-center px-4 sm:px-6 pt-16 sm:pt-20 pb-8 z-10 overflow-hidden">
  <!-- Background Glow subtil -->
  <div 
    class="absolute top-0 left-0 w-96 h-96 bg-[var(--color-glow-primary)] rounded-full blur-[120px] -translate-x-1/2 -translate-y-1/2 opacity-30" 
    aria-hidden="true"
  ></div>
  
  <div class="max-w-7xl mx-auto w-full">
    <div class="flex flex-col lg:grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      
      <!-- Profile Card -->
      <div class="relative z-10 w-full lg:order-2 mb-12 lg:mb-0">
        <ProfileCard lang={lang} />
      </div>

      <!-- Content Principal -->
      <div class="relative z-10 space-y-6 lg:space-y-8 text-center lg:text-left lg:order-1">
        <div class="space-y-2">
          <p class="text-[var(--color-text-muted)] font-mono text-xs lg:text-sm tracking-[0.2em] uppercase font-medium">
            {t.hero.subtitle}
          </p>
          
          <h1 class="hero-title-main text-[var(--color-text)]">
            {t.hero.title1}
          </h1>
          
          <h2 class="hero-title-sub text-[var(--color-text-muted)]">
            {t.hero.title2}
          </h2>
        </div>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
          <Button
            href={getLocalizedPath('/portfolio', lang)}
            variant="primary"
            className="w-full sm:w-auto text-center"
          >
            {t.hero.cta}
          </Button>
          <Button
            href={getLocalizedPath('/contact', lang)}
            variant="ghost"
            className="flex items-center text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition group"
          >
            {lang === 'fr' ? 'Me contacter' : 'Get in touch'}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 group-hover:translate-x-1 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
        </div>

        <!-- Stats épurées (desktop uniquement) -->
        <div class="hidden lg:flex gap-8 pt-8 border-t border-[var(--color-border)]">
          <div>
            <p class="text-xs text-[var(--color-text-muted)] mb-1">{t.hero.stat1Label}</p>
            <p class="text-xl font-bold text-[var(--color-text)]">{t.hero.stat1Value}</p>
          </div>
          <div>
            <p class="text-xs text-[var(--color-text-muted)] mb-1">{t.hero.stat2Label}</p>
            <p class="text-xl font-bold text-[var(--color-text)]">{t.hero.stat2Value}</p>
          </div>
          <div>
            <p class="text-xs text-[var(--color-text-muted)] mb-1">{t.hero.stat3Label}</p>
            <p class="text-xl font-bold text-[var(--color-text)]">{t.hero.stat3Value}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>