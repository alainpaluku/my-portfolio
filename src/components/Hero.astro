---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import ProfileCard from './ProfileCard.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;
---

<header class="relative min-h-screen flex items-center px-4 sm:px-6 pt-16 sm:pt-20 pb-8 z-10 overflow-hidden">
  <!-- Background Glow with parallax -->
  <div class="parallax absolute top-0 left-0 w-48 sm:w-64 lg:w-96 h-48 sm:h-64 lg:h-96 bg-[var(--color-glow-primary)] rounded-full blur-[60px] sm:blur-[80px] lg:blur-[100px] -translate-x-1/2 -translate-y-1/2" data-speed="0.3"></div>
  
  <div class="max-w-7xl mx-auto w-full">
    <div class="flex flex-col lg:grid lg:grid-cols-2 gap-4 lg:gap-16 items-center">
      
      <!-- Profile Card (First on mobile) -->
      <div class="relative z-10 w-full lg:order-2 mb-20 sm:mb-16 lg:mb-0">
        <ProfileCard lang={lang} />
      </div>

      <!-- CTA Content -->
      <div class="relative z-10 space-y-4 sm:space-y-5 lg:space-y-8 text-center lg:text-left lg:order-1">
        <p class="animate-fade-in-up text-[var(--color-text)] font-mono text-[10px] sm:text-xs lg:text-sm tracking-[0.1em] sm:tracking-[0.15em] lg:tracking-[0.2em] uppercase font-semibold">
          {t.hero.subtitle}
        </p>
        
        <div class="hero-title hero-title-animated">
          <h1 class="hero-title-main animate-fade-in-up animate-delay-100">
            {t.hero.title1}
          </h1>
          <h2 class="hero-title-sub animate-fade-in-up animate-delay-200">
            {t.hero.title2}
          </h2>
        </div>

        {t.hero.description && (
          <p class="animate-fade-in-up animate-delay-200 text-[var(--color-text-muted)] max-w-xl mx-auto lg:mx-0 text-xs sm:text-sm lg:text-base font-light leading-relaxed">
            {t.hero.description}
          </p>
        )}

        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-3 sm:gap-4">
          <a href={`${basePath}/portfolio`} class="btn-primary w-full sm:w-auto text-center text-sm sm:text-base">
            {t.hero.cta}
          </a>
          <a href={`${basePath}/about`} class="flex items-center text-[var(--color-text)] hover:text-[var(--color-text)] transition group text-xs sm:text-sm">
            {lang === 'fr' ? 'En savoir plus' : 'Learn More'}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 group-hover:translate-x-1 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Stats (visible on desktop) -->
        <div class="hidden lg:flex gap-6 xl:gap-8 pt-6 border-t border-[var(--color-border)] mt-8">
          <div class="stat-number">
            <p class="text-[10px] xl:text-xs text-[var(--color-text-muted)] mb-1">{t.hero.stat1Label}</p>
            <p class="text-lg xl:text-xl font-bold text-[var(--color-text)]">{t.hero.stat1Value}</p>
          </div>
          <div class="stat-number">
            <p class="text-[10px] xl:text-xs text-[var(--color-text-muted)] mb-1">{t.hero.stat2Label}</p>
            <p class="text-lg xl:text-xl font-bold text-[var(--color-text)]">{t.hero.stat2Value}</p>
          </div>
          <div class="stat-number">
            <p class="text-[10px] xl:text-xs text-[var(--color-text-muted)] mb-1">{t.hero.stat3Label}</p>
            <p class="text-lg xl:text-xl font-bold text-[var(--color-text)]">{t.hero.stat3Value}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
