---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import ProfileCard from './ProfileCard.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-12 sm:py-16 lg:py-24 px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
  <!-- Header -->
  <div class="text-center mb-10 sm:mb-14">
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-2 uppercase tracking-wide">{t.about.headerName}</h1>
    <p class="text-sm sm:text-base text-[var(--color-text-muted)] uppercase tracking-widest font-mono">{t.about.headerTitle}</p>
  </div>

  <!-- Layout en deux colonnes sur desktop -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
    <!-- Colonne gauche - Profile (desktop) -->
    <div class="order-2 lg:order-1">
      <div class="flex justify-center lg:justify-start mb-8">
        <ProfileCard lang={lang} showSocials={true} />
      </div>
      
      <div class="glass-card p-5 sm:p-6 rounded-xl">
        <p class="text-[var(--color-text-muted)] text-sm sm:text-base leading-relaxed text-center lg:text-left">
          {t.about.headerSubtitle}
        </p>
      </div>
    </div>

    <!-- Colonne droite - Contenu (desktop) -->
    <div class="order-1 lg:order-2 space-y-6 lg:space-y-8">
      <!-- Education -->
      <div class="glass-card p-5 sm:p-6 rounded-xl">
        <h2 class="text-base sm:text-lg font-bold text-[var(--color-text)] mb-6 text-center lg:text-left uppercase tracking-widest font-mono">
          {t.about.educationTitle}
        </h2>

        <div class="space-y-4">
          {t.about.educationList.map((item) => (
            <div class="bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl p-4 sm:p-5">
              <p class="text-xs sm:text-sm font-bold text-[var(--color-text)] uppercase tracking-wider mb-2">
                {item.degree}
              </p>
              <p class="text-xs sm:text-sm text-[var(--color-text-muted)] leading-relaxed">
                {item.school}
              </p>
            </div>
          ))}
        </div>
      </div>

      <!-- Skills -->
      <div class="glass-card p-5 sm:p-6 rounded-xl">
        <h2 class="text-base sm:text-lg font-bold text-[var(--color-text)] mb-6 text-center lg:text-left uppercase tracking-widest font-mono">
          {t.about.skillsTitle}
        </h2>

        <div class="grid grid-cols-1 gap-4">
          {t.about.skillCategories.map((cat) => (
            <div class="bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl p-4 sm:p-5">
              <h3 class="text-xs sm:text-sm font-bold text-[var(--color-text)] uppercase tracking-wider mb-3">
                {cat.title}
              </h3>
              <ul class="space-y-2">
                {cat.items.map((item) => (
                  <li class="text-xs sm:text-sm text-[var(--color-text-muted)] leading-relaxed">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>