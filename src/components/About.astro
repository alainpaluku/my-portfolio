---
import { useTranslations, type Lang, defaultLang } from '../i18n/translations';
import ProfileCard from './ProfileCard.astro';
import Section from './base/Section.astro';
import Button from './ui/Button.astro';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<Section title={t.about.headerName} subtitle={t.about.headerTitle}>
  <!-- Layout en deux colonnes sur desktop -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
    <!-- Colonne gauche - Profile + Formation -->
    <div class="order-1 lg:order-1 space-y-6 lg:space-y-8">
      <!-- Profile Card -->
      <div class="flex justify-center lg:justify-start">
        <ProfileCard lang={lang} showSocials={true} />
      </div>
      
      <!-- Education -->
      <div class="glass-card p-5 sm:p-6 rounded-xl">
        <h2 class="text-base sm:text-lg font-bold text-[var(--color-text)] mb-6 text-center lg:text-left uppercase tracking-widest font-mono">
          {t.about.educationTitle}
        </h2>

        <div class="space-y-4">
          {t.about.educationList.map((item) => (
            <div class="bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl p-4 sm:p-5">
              <p class="text-xs sm:text-sm font-bold text-[var(--color-text)] uppercase tracking-wider mb-2">
                {item.degree}
              </p>
              <p class="text-xs sm:text-sm text-[var(--color-text-muted)] leading-relaxed">
                {item.school}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Colonne droite - Skills + Portfolio CTA -->
    <div class="order-2 lg:order-2 space-y-6 lg:space-y-8">
      <!-- Skills -->
      <div class="glass-card p-5 sm:p-6 rounded-xl">
        <h2 class="text-base sm:text-lg font-bold text-[var(--color-text)] mb-6 text-center lg:text-left uppercase tracking-widest font-mono">
          {t.about.skillsTitle}
        </h2>

        <div class="grid grid-cols-1 gap-4">
          {t.about.skillCategories.map((cat) => (
            <div class="bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl p-4 sm:p-5">
              <h3 class="text-xs sm:text-sm font-bold text-[var(--color-text)] uppercase tracking-wider mb-3">
                {cat.title}
              </h3>
              <ul class="space-y-2">
                {cat.items.map((item) => (
                  <li class="text-xs sm:text-sm text-[var(--color-text-muted)] leading-relaxed">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- Portfolio CTA Card -->
      <div class="glass-card p-5 sm:p-6 rounded-xl text-center lg:text-left">
        <h2 class="text-base sm:text-lg font-bold text-[var(--color-text)] mb-4 uppercase tracking-widest font-mono">
          {t.about.portfolioTitle}
        </h2>
        <p class="text-xs sm:text-sm text-[var(--color-text-muted)] leading-relaxed mb-6">
          {t.about.portfolioDescription}
        </p>
        <Button
          href={`/${lang}/portfolio`}
          variant="outline"
          className="inline-flex items-center gap-2 text-sm"
        >
          {t.about.portfolioCta}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
      </div>
    </div>
  </div>
</Section>