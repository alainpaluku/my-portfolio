---
import { type Lang } from '../../i18n/translations';
import { getProjectUrl, getArticleUrl } from '../../utils/routing';

interface Props {
  type: 'project' | 'article' | 'service';
  data: any;
  lang: Lang;
  className?: string;
  showLink?: boolean;
  linkText?: string;
}

const { type, data, lang, className = '', showLink = false, linkText = 'Learn More' } = Astro.props;

const getUrl = () => {
  switch (type) {
    case 'project':
      return data.slug ? getProjectUrl(data.slug, lang) : '#';
    case 'article':
      return data.slug ? getArticleUrl(data.slug, lang) : '#';
    default:
      return '#';
  }
};

const url = getUrl();
const isClickable = type === 'project' || type === 'article';
const Component = isClickable ? 'a' : 'div';
// Même aspect ratio pour projets et articles
const aspectRatio = 'aspect-video';
---

<Component 
  href={isClickable ? url : undefined}
  class={`block group glass-card cursor-pointer ${className}`}
>
  <!-- Image -->
  {data.image && (
    <div class={`${aspectRatio} overflow-hidden`}>
      <img 
        src={data.image} 
        alt={data.title?.[lang] || 'Image'}
        width="800"
        height="450"
        loading="lazy"
        class="w-full h-full object-cover transition-colors duration-300"
        onerror="this.src='/images/placeholder.png'"
      />
    </div>
  )}
  
  <!-- Content - Même style pour projets et articles -->
  <div class="p-3 sm:p-4">
    <!-- Category & Meta -->
    <div class="flex items-center justify-between mb-2 sm:mb-3">
      {data.category?.[lang] && (
        <span class="caption uppercase tracking-wider font-semibold text-[var(--color-accent)]">
          {data.category[lang]}
        </span>
      )}
      {data.readTime && (
        <span class="caption font-medium text-[var(--color-text-muted)]">
          {data.readTime}
        </span>
      )}
    </div>

    <!-- Title -->
    {data.title?.[lang] && (
      <h3 class="body font-bold mb-2 transition-colors line-clamp-2 text-[var(--color-text)] group-hover:text-[var(--color-accent)]">
        {data.title[lang]}
      </h3>
    )}

    <!-- Description/Excerpt -->
    {data.excerpt?.[lang] && (
      <p class="body-sm leading-relaxed mb-2 sm:mb-3 line-clamp-2 text-[var(--color-text-muted)]">
        {data.excerpt[lang]}
      </p>
    )}

    {data.description?.[lang] && (
      <p class="body-sm leading-relaxed mb-2 sm:mb-3 line-clamp-2 text-[var(--color-text-muted)]">
        {data.description[lang]}
      </p>
    )}

    <!-- Tags -->
    {data.tags && Array.isArray(data.tags) && data.tags.length > 0 && (
      <div class="flex flex-wrap gap-1 mt-2">
        {data.tags.map((tag: string) => (
          <span class="px-1.5 sm:px-2 py-0.5 caption rounded-full font-medium bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-[var(--color-text-muted)]">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- Tools -->
    {data.tools?.[lang] && (
      <p class="caption text-[var(--color-text-muted)] mt-2 leading-relaxed">
        {data.tools[lang]}
      </p>
    )}

    <!-- Date & Read More -->
    {(data.date || showLink) && (
      <div class="flex items-center justify-between mt-3 pt-2 border-t border-[var(--color-border)]">
        {data.date && (
          <time class="caption text-[var(--color-text-muted)]">
            {new Date(data.date).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric'
            })}
          </time>
        )}
        {showLink && (
          <span class="caption text-[var(--color-accent)] font-semibold group-hover:underline">
            {linkText}
          </span>
        )}
      </div>
    )}
  </div>
</Component>