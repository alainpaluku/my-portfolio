---
interface Props {
  src: string;
  alt: string;
  width?: number | string;
  height?: number | string;
  fallback?: string;
  className?: string;
  loading?: 'lazy' | 'eager';
  decoding?: 'async' | 'sync' | 'auto';
  priority?: boolean;
}

const { 
  src, 
  alt, 
  width, 
  height, 
  fallback = '/images/placeholder.png',
  className = '',
  loading = 'lazy',
  decoding = 'async',
  priority = false
} = Astro.props;

// Validation des props
if (!src) {
  console.warn('ImageWithFallback: src is required');
}

if (!alt) {
  console.warn('ImageWithFallback: alt is required for accessibility');
}

const imageId = `img-${Math.random().toString(36).substr(2, 9)}`;

// Optimiser le loading pour les images critiques
const finalLoading = priority ? 'eager' : loading;
const fetchPriority = priority ? 'high' : 'auto';
---

<img 
  id={imageId}
  src={src || fallback} 
  alt={alt || 'Image'}
  width={width}
  height={height}
  loading={finalLoading}
  decoding={decoding}
  fetchpriority={fetchPriority}
  class={`image-with-fallback ${className}`}
/>

<script define:vars={{ imageId, fallback }} is:inline>
  const img = document.getElementById(imageId);
  if (img) {
    img.addEventListener('error', function() {
      console.warn(`Image failed to load: ${this.src}. Using fallback.`);
      this.src = fallback;
      this.classList.add('fallback-image');
    });

    // Ajouter un indicateur de chargement
    img.addEventListener('load', function() {
      this.classList.add('loaded');
    });

    // Intersection Observer pour lazy loading amélioré
    if ('IntersectionObserver' in window && this.loading === 'lazy') {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            observer.unobserve(entry.target);
          }
        });
      }, { rootMargin: '50px' });
      
      observer.observe(img);
    }
  }
</script>

<style>
  .image-with-fallback {
    transition: opacity 0.3s ease, transform 0.3s ease;
    opacity: 0;
  }

  .image-with-fallback.loaded {
    opacity: 1;
  }

  .image-with-fallback.fallback-image {
    filter: grayscale(0.3) opacity(0.8);
  }

  .image-with-fallback.in-view {
    transform: scale(1.02);
  }

  /* Optimisation pour les images critiques */
  .image-with-fallback[loading="eager"] {
    opacity: 1;
  }
</style>