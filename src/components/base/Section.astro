---
import SectionHeader from '../SectionHeader.astro';

interface Props {
  title?: string;
  subtitle?: string;
  className?: string;
  headerClassName?: string;
  showHeader?: boolean;
  id?: string;
  compact?: boolean;
}

const {
  title,
  subtitle,
  className = '',
  headerClassName = '',
  showHeader = true,
  id,
  compact = false
} = Astro.props;

const shouldShowHeader = showHeader && title;
const sectionClass = compact ? 'section-compact' : 'section';
---

<section 
  id={id}
  class={`${sectionClass} ${className}`}
>
  {shouldShowHeader && (
    <SectionHeader
      title={title}
      subtitle={subtitle}
      class={headerClassName}
    />
  )}
  <slot />
</section>