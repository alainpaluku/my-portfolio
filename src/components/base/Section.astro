---
import SectionHeader from '../SectionHeader.astro';

interface Props {
  title?: string;
  subtitle?: string;
  className?: string;
  headerClassName?: string;
  showHeader?: boolean;
  id?: string;
}

const {
  title,
  subtitle,
  className = '',
  headerClassName = '',
  showHeader = true,
  id,
} = Astro.props;

const shouldShowHeader = showHeader && title;
---

<section 
  id={id}
  class={`py-8 sm:py-12 lg:py-16 xl:py-24 px-3 sm:px-4 md:px-6 lg:px-12 max-w-7xl mx-auto ${className}`}
>
  {shouldShowHeader && (
    <SectionHeader
      title={title}
      subtitle={subtitle}
    />
  )}
  <slot />
</section>