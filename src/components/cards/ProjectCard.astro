---
import Icon from '../Icon.astro';
import { type Lang } from '../../i18n/translations';

interface Props {
  title: { en: string; fr: string };
  category: { en: string; fr: string };
  image: string;
  tags: string[];
  lang: Lang;
  slug?: string;
  showLink?: boolean;
  linkText?: string;
}

const { title, category, image, tags, lang, slug, showLink = false, linkText = 'View Project' } = Astro.props;
const projectUrl = slug ? `/${lang}/projects/${slug}` : '#';
---

<a href={projectUrl} class="block group relative overflow-hidden rounded-xl sm:rounded-2xl glass-card cursor-pointer hover:border-[var(--color-accent)]/30 transition-all duration-300">
  <div class="aspect-[4/3] overflow-hidden">
    <img 
      src={image} 
      alt={title[lang]}
      loading="lazy"
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg)] via-[var(--color-bg)]/60 to-transparent"></div>
  </div>
  
  <div class="absolute bottom-0 left-0 right-0 p-3 sm:p-4">
    <span class="text-[10px] sm:text-xs text-[var(--color-accent)] uppercase tracking-wider font-semibold">{category[lang]}</span>
    <h3 class="text-base sm:text-lg font-bold mt-1 text-[var(--color-text)]">{title[lang]}</h3>
    <div class="flex flex-wrap gap-1 mt-2">
      {tags.map(tag => (
        <span class="px-1.5 sm:px-2 py-0.5 text-[10px] sm:text-xs bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-full text-[var(--color-text-muted)] font-medium">{tag}</span>
      ))}
    </div>
    {showLink && (
      <span class="inline-flex items-center text-xs sm:text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors mt-3">
        {linkText}
        <Icon name="arrowRight" size={14} class="ml-1.5 group-hover:translate-x-1 transition-transform" />
      </span>
    )}
  </div>
</a>
