---
import { icons } from '../icons';

interface Props {
  icon: keyof typeof icons;
  title: string;
  desc: string;
  tools?: string;
  color?: 'primary' | 'secondary' | 'accent';
}

const { icon, title, desc, tools, color = 'primary' } = Astro.props;

const colorClasses = {
  primary: 'bg-primary/20 text-primary',
  secondary: 'bg-secondary/20 text-secondary',
  accent: 'bg-accent/20 text-accent',
};
---

<div class="glass-card p-4 sm:p-5 lg:p-6 rounded-xl lg:rounded-2xl hover:bg-white/5 transition-colors group">
  <div class="flex items-start gap-3 mb-3">
    <div class={`p-2 sm:p-2.5 lg:p-3 ${colorClasses[color]} rounded-lg group-hover:text-white transition-colors flex-shrink-0`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sm:w-5 sm:h-5 lg:w-6 lg:h-6" set:html={icons[icon]} />
    </div>
    <h3 class="text-sm sm:text-base lg:text-lg font-bold leading-tight pt-1">{title}</h3>
  </div>
  <p class="text-gray-400 leading-relaxed mb-2 sm:mb-3 text-xs sm:text-sm lg:text-base">{desc}</p>
  {tools && <span class="text-[9px] sm:text-[10px] lg:text-xs text-gray-500 uppercase block">{tools}</span>}
</div>
