---
import Icon from '../Icon.astro';
import { type Lang } from '../../i18n/translations';
import { formatDate } from '../../utils/date';

interface Props {
  title: { en: string; fr: string };
  excerpt: { en: string; fr: string };
  category: { en: string; fr: string };
  image: string;
  date: string;
  readTime: string;
  lang: Lang;
  readMoreText?: string;
}

const { title, excerpt, category, image, date, readTime, lang, readMoreText = 'Read More' } = Astro.props;
---

<article class="glass-card rounded-xl sm:rounded-2xl overflow-hidden group hover:border-[var(--color-accent)]/30 transition-all duration-300">
  <div class="aspect-video overflow-hidden">
    <img 
      src={image} 
      alt={title[lang]}
      loading="lazy"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
  </div>
  <div class="p-4 sm:p-5">
    <div class="flex items-center justify-between mb-2 sm:mb-3">
      <span class="text-[10px] sm:text-xs text-[var(--color-accent)] uppercase tracking-wider font-semibold">{category[lang]}</span>
      <span class="text-[10px] sm:text-xs text-[var(--color-text-muted)] font-medium">{readTime}</span>
    </div>
    <h3 class="text-sm sm:text-base font-bold mb-2 group-hover:text-[var(--color-accent)] transition-colors line-clamp-2 text-[var(--color-text)]">
      {title[lang]}
    </h3>
    <p class="text-[var(--color-text-muted)] text-xs sm:text-sm leading-relaxed mb-2 sm:mb-3 line-clamp-2">{excerpt[lang]}</p>
    <div class="flex items-center justify-between">
      <span class="text-[10px] sm:text-xs text-[var(--color-text-muted)]">{formatDate(date, lang)}</span>
      <a href="#" class="text-xs sm:text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors inline-flex items-center gap-1">
        {readMoreText}
        <Icon name="chevronRight" size={12} />
      </a>
    </div>
  </div>
</article>
