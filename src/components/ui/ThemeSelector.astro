---
/**
 * Sélecteur de thème avec combobox
 */
import Combobox from './Combobox.astro';
import Icon from '../Icon.astro';

interface Props {
  lang?: 'en' | 'fr';
}

const { lang = 'en' } = Astro.props;

const themeOptions = [
  {
    value: 'light',
    label: lang === 'fr' ? 'Clair' : 'Light',
    icon: 'sun'
  },
  {
    value: 'dark', 
    label: lang === 'fr' ? 'Sombre' : 'Dark',
    icon: 'moon'
  },
  {
    value: 'system',
    label: lang === 'fr' ? 'Système' : 'System', 
    icon: 'monitor'
  }
];
---

<!-- Icônes SVG pour le combobox -->
<svg style="display: none;">
  <defs>
    <g id="icon-sun">
      <circle cx="12" cy="12" r="5"/>
      <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
    </g>
    <g id="icon-moon">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </g>
    <g id="icon-monitor">
      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
      <line x1="8" y1="21" x2="16" y2="21"/>
      <line x1="12" y1="17" x2="12" y2="21"/>
    </g>
  </defs>
</svg>

<Combobox 
  id="theme-selector"
  options={themeOptions}
  currentValue="light"
  position="bottom-right"
/>

<script>
  import { themeManager } from '../../scripts/themeTransitions';

  class ThemeSelector {
    private currentTheme: string = 'light';

    init() {
      // Détecter le thème actuel
      this.detectCurrentTheme();
      
      // Écouter les changements de combobox
      document.addEventListener('combobox-change', (e: any) => {
        if (e.detail.id === 'theme-selector') {
          this.changeTheme(e.detail.value);
        }
      });

      // Écouter les changements de thème système
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if (this.currentTheme === 'system') {
          this.applySystemTheme();
        }
      });

      // Mettre à jour l'icône initiale
      this.updateTriggerIcon();
    }

    detectCurrentTheme() {
      const savedTheme = localStorage.getItem('theme');
      const hasSystemPreference = localStorage.getItem('theme-system') === 'true';
      
      if (hasSystemPreference || !savedTheme) {
        this.currentTheme = 'system';
      } else {
        this.currentTheme = savedTheme;
      }
    }

    async changeTheme(newTheme: string) {
      this.currentTheme = newTheme;
      
      if (newTheme === 'system') {
        localStorage.setItem('theme-system', 'true');
        localStorage.removeItem('theme');
        this.applySystemTheme();
      } else {
        localStorage.setItem('theme', newTheme);
        localStorage.removeItem('theme-system');
        
        // Utiliser themeManager pour les transitions
        if (typeof themeManager !== 'undefined' && themeManager.toggleTheme) {
          await themeManager.toggleTheme();
        } else {
          this.applyTheme(newTheme);
        }
      }
      
      this.updateTriggerIcon();
    }

    applySystemTheme() {
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const systemTheme = prefersDark ? 'dark' : 'light';
      this.applyTheme(systemTheme);
    }

    applyTheme(theme: string) {
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    }

    updateTriggerIcon() {
      const trigger = document.querySelector('[data-trigger="theme-selector"] .combobox-icon');
      if (!trigger) return;

      let iconId = 'icon-sun';
      
      if (this.currentTheme === 'system') {
        iconId = 'icon-monitor';
      } else if (this.currentTheme === 'dark') {
        iconId = 'icon-moon';
      }

      const svg = trigger.querySelector('svg use');
      if (svg) {
        svg.setAttribute('href', `#${iconId}`);
      }
    }

    getCurrentTheme() {
      return this.currentTheme;
    }
  }

  // Initialiser le sélecteur de thème
  const themeSelector = new ThemeSelector();
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => themeSelector.init());
  } else {
    themeSelector.init();
  }

  // Exporter pour utilisation globale
  (window as any).themeSelector = themeSelector;
</script>