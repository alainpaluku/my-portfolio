---
import { type Lang } from '../../i18n/translations';
import SectionHeader from '../SectionHeader.astro';
import FilterButton from './FilterButton.astro';

interface Props {
  title: string;
  subtitle: string;
  items: any[];
  categories: Record<string, { en: string; fr: string }>;
  cardComponent: any;
  filterId: string;
  gridId: string;
  cardClass: string;
  categoryKey: string;
  lang: Lang;
  gridCols?: string;
}

const { 
  title, 
  subtitle, 
  items, 
  categories, 
  cardComponent: Card, 
  filterId, 
  gridId, 
  cardClass, 
  categoryKey,
  lang,
  gridCols = "grid-cols-1 md:grid-cols-2"
} = Astro.props;

const categoriesArray = Object.entries(categories) as [string, { en: string; fr: string }][];
---

<section class="py-8 sm:py-12 lg:py-16 xl:py-24 px-3 sm:px-4 md:px-6 lg:px-12 max-w-7xl mx-auto">
  <SectionHeader title={title} subtitle={subtitle} />

  <!-- Filtres -->
  <div class="flex flex-wrap justify-center gap-1.5 sm:gap-2 md:gap-3 mb-6 sm:mb-8 lg:mb-12 px-2" id={filterId}>
    {categoriesArray.map(([key, label]) => (
      <FilterButton filter={key} label={label[lang]} isActive={key === 'all'} />
    ))}
  </div>

  <!-- Grille -->
  <div class={`grid ${gridCols} gap-3 sm:gap-4 lg:gap-6`} id={gridId}>
    {items.map((item) => (
      <div class={cardClass} data-category={item[categoryKey]}>
        <Card {...item} lang={lang} />
      </div>
    ))}
  </div>
</section>

<script define:vars={{ filterId, cardClass }}>
  import { initFilterGrid } from '../../scripts/filterGrid';
  initFilterGrid(filterId, cardClass);
</script>