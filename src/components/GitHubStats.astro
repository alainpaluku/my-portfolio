---
/**
 * Composant pour afficher les statistiques GitHub en temps réel
 */
import { getGitHubStats } from '../data/githubStats';

const githubStats = await getGitHubStats();
---

<!-- Statistiques GitHub cachées pour utilisation par JavaScript -->
<script define:vars={{ githubStats }}>
  // Stocker les stats GitHub pour utilisation dans d'autres composants
  window.githubStats = githubStats;
</script>